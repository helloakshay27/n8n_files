      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const items = $input.all();\n\nconst find = (type) =>\n  items.find(i => i.json.promptType === type)?.json?.content || \"\";\n\nconst videoSummary          = find(\"videoSummary\");\nconst userGuide             = find(\"userGuide\");\nconst productOverview       = find(\"productOverview\");\nconst productDescription    = find(\"productDescription\");\nconst researchReport        = find(\"researchReport\");\nconst communicationStrategy = find(\"communicationStrategy\");\nconst onePager              = find(\"onePager\");\nconst elevatorPitch         = find(\"elevatorPitch\");\nconst industryFeatureList   = find(\"industryFeatureList\");\nconst marketingScript       = find(\"marketingScript\");\nconst storyboard            = find(\"storyboard\");\nconst screenplay            = find(\"screenplay\");\n\nreturn [{\n  json: {\n    productName: items[0]?.json?.productName || \"Product\",\n\n    // Individual fields (for placeholders or selective use)\n    videoSummary,\n    userGuide,\n    productOverview,\n    productDescription,\n    researchReport,\n    communicationStrategy,\n    onePager,\n    elevatorPitch,\n    industryFeatureList,\n    marketingScript,\n    storyboard,\n    screenplay,\n\n    // Full combined document (for single insert into Google Doc)\n    fullDocument: `\nVIDEO SUMMARY\n${videoSummary}\n\nUSER GUIDE\n${userGuide}\n\nPRODUCT OVERVIEW\n${productOverview}\n\nPRODUCT DESCRIPTION\n${productDescription}\n\nRESEARCH REPORT\n${researchReport}\n\nCOMMUNICATION STRATEGY\n${communicationStrategy}\n\nONE PAGER\n${onePager}\n\nELEVATOR PITCH\n${elevatorPitch}\n\nINDUSTRY FEATURE LIST\n${industryFeatureList}\n\nMARKETING SCRIPT\n${marketingScript}\n\nSTORYBOARD\n${storyboard}\n\nSCREENPLAY\n${screenplay}\n    `.trim()\n  }\n}];",
        "notice": ""
      },
