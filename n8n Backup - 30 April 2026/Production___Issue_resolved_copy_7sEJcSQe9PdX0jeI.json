            "query": "SELECT\n  i.*,\n  i.id                        AS issue_id,\n  i.title                     AS issue_title,\n  i.status                    AS issue_status,\n  i.updated_at                AS issue_updated_at,\n  i.responsible_person_id     AS issue_owner_id,\n\n  io.firstname                AS issue_owner_firstname,\n  io.lastname                 AS issue_owner_lastname,\n  io.email                    AS issue_owner_email,\n\n  pm.id                       AS project_id,\n  pm.title                    AS project_title,\n\n  pmo.email                   AS project_manager_email,\n  pmo.firstname               AS project_manager_firstname,\n  pmo.lastname                AS project_manager_lastname,\n\n  reporter.email              AS reporter_email,\n  reporter.firstname          AS reporter_firstname,\n  reporter.lastname           AS reporter_lastname,\n\n  t.id                        AS task_id,\n  t.title                     AS task_title,\n  t.responsible_person_id     AS task_owner_id,\n  tp.firstname                AS task_owner_firstname,\n  tp.lastname                 AS task_owner_lastname,\n  tp.email                    AS task_owner_email,\n\n  m.id                        AS milestone_id,\n  m.title                     AS milestone_title\n\nFROM issues i\n\nJOIN project_managements pm\n  ON pm.id = i.project_management_id\n\nJOIN spree_users pmo\n  ON pmo.id = pm.owner_id\n\nJOIN spree_users reporter\n  ON reporter.id = i.created_by_id\n\nJOIN spree_users io\n  ON io.id = i.responsible_person_id\n\nLEFT JOIN task_managements t\n  ON t.id = i.task_management_id\n\nLEFT JOIN spree_users tp\n  ON tp.id = t.responsible_person_id\n\nLEFT JOIN milestones m\n  ON m.id = i.milestone_id\n\nWHERE\n  i.status IN ('completed', 'closed')\n  AND i.updated_at >= UTC_TIMESTAMP() - INTERVAL 10 MINUTE\n  AND i.updated_at > i.created_at\n  AND io.organization_id IN (13, 14, 59, 84);",
            "options": {}
          },
          "type": "n8n-nodes-base.mySql",
          "typeVersion": 2.5,
          "position": [
