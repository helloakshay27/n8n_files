        "toEmail": "={{$json.project_manager_email}}",
        "subject": "=Issue Overdue Alert: {{$json.issue_title}}\n\n",
        "html": "=Dear {{$json.project_manager_firstname}} {{$json.project_manager_lastname}},\n\nThe issue <b>{{$json.issue_title}}</b> has exceeded its planned resolution timeline and is currently overdue.\n\n<b>Overdue Details</b>\n* Issue Title: {{$json.issue_title}}\n* Planned End Date: {{$json.issue_end_date_ist}}\n* Overdue By: {{$json.overdue_days}} days\n* Current Status: {{$json.status}}\n* Assigned Owner ID: {{$json.responsible_person_id}}\n\nPlease provide an immediate update with revised resolution timelines or closure remarks to prevent further escalation.\n\nRegards,\n<b>PMO – Issue Escalation Desk</b\n",
        "options": {}
      },
