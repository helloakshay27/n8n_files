    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  i.*,\n  i.id                    AS issue_id,\n  i.title                 AS issue_title,\n\n  -- convert end_date to IST\n  CONVERT_TZ(i.end_date, '+00:00', '+05:30') AS issue_end_date_ist,\n\n  -- overdue days based on IST date\n  DATEDIFF(\n    DATE(CONVERT_TZ(UTC_TIMESTAMP(), '+00:00', '+05:30')),\n    DATE(CONVERT_TZ(i.end_date, '+00:00', '+05:30'))\n  ) AS overdue_days,\n\n  pm.id                   AS project_id,\n  pm.title                AS project_title,\n\n  -- issue owner\n  io.email                AS issue_owner_email,\n  io.firstname            AS issue_owner_firstname,\n  io.lastname             AS issue_owner_lastname,\n\n  -- project manager\n  pmo.email               AS project_manager_email,\n  pmo.firstname           AS project_manager_firstname,\n  pmo.lastname            AS project_manager_lastname\n\nFROM issues i\n\nJOIN spree_users io\n  ON io.id = i.responsible_person_id\n\nJOIN project_managements pm\n  ON pm.id = i.project_management_id\n\nJOIN spree_users pmo\n  ON pmo.id = pm.owner_id\n\nWHERE\n  DATE(CONVERT_TZ(i.end_date, '+00:00', '+05:30'))\n    < DATE(CONVERT_TZ(UTC_TIMESTAMP(), '+00:00', '+05:30'))\n  AND i.status NOT IN ('completed', 'closed');\n",
        "options": {}
      },
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.5,
      "position": [
        -224,
        -240
      ],
      "id": "13266ed9-a627-4e24-a890-f56c06c64721",
