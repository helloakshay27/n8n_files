    {
      "parameters": {
        "fromEmail": "notifications@lockated.com",
        "toEmail": "={{$json.responsible_person_email}}\n",
        "subject": "=New Task Assigned: {{$json.task_title}}\n\n\n",
        "html": "=<p>Dear {{$json.responsible_person_first_name}} {{$json.responsible_person_last_name}},</p>\n\n<p>You have been assigned a new task requiring your attention.</p>\n\n<p>Task Details:<br>\n* Task Title: {{$json.task_title}}<br>\n* Description: {{$json.description}}<br>\n* Status: {{$json.status}}<br>\n* Priority: {{$json.priority}}<br>\n* Assigned To: {{$json.responsible_person_first_name}} {{$json.responsible_person_first_name}}</p>\n\n<p>Please begin execution and keep the task status updated.</p>\n\n<p>Regards,<br>\nTask Management System</p>",
        "options": {}
      },
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [
        80,
        -272
      ],
      "id": "a60ec748-9e7f-452c-a122-661c0b5e7ebb",
      "name": "Task Owner",
      "webhookId": "8c21ec8e-b0d0-4411-bf36-6d2f28733a4f",
      "credentials": {
        "smtp": {
          "id": "e6BxRubia0RizPKp",
          "name": "Lockated Local SMTP"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "allIncomingItems",
        "options": {}
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.5,
      "position": [
        352,
        -48
      ],
      "id": "59e444a3-a435-403f-a4f0-c62f08865dfb",
      "name": "Respond to Webhook",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  t.id            AS task_id,\n  t.title         AS task_title,\n  t.description,\n  t.status,\n  t.priority,\n  t.target_date,\n  t.created_at    AS task_created_at,\n  t.parent_id     AS parent_id,\n\n  -- responsible person\n  u.id            AS responsible_person_id,\n  u.firstname     AS responsible_person_first_name,\n  u.lastname      AS responsible_person_last_name,\n  u.email         AS responsible_person_email\n\nFROM task_managements t\nJOIN spree_users u\n  ON u.id = t.responsible_person_id\n\nWHERE\n  t.created_at >= UTC_TIMESTAMP() - INTERVAL 60 MINUTE\n  AND t.parent_id IS NULL;",
        "options": {}
      },
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.5,
      "position": [
        -192,
        -256
      ],
      "id": "63239da3-a6a0-4a04-be3c-b426f936cb5d",
      "name": "Fetch the created annd assigned tasks in pas 1 hr",
      "credentials": {
        "mySql": {
          "id": "FGCPCtEG47rFAJ4J",
          "name": "New FM UAT Task Management Database"
        }
      }
    },
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours"
            }
          ]
        }
      },
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.3,
      "position": [
        -464,
        0
      ],
      "id": "02b3b8a5-4308-4563-8305-9f069f9c3722",
      "name": "Schedule Trigger"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT * from task_managements ORDER by created_at DESC LIMIT 5;",
