    {
      "parameters": {
        "jsCode": "const output = [];\n\nfor (const item of items) {\n\n  output.push({\n    json: {\n      customer_id: item.json.customer_id,\n      customer_mobile: item.json.customer_mobile,\n      customer_name: item.json.customer_name,\n      points: 1000,\n      reason: \"Booking within 30 days of Site Visit\",\n      booking_date: item.json.Booking_Date,\n      sv_date: item.json.SV_Date__c,\n      booking_id: item.json.X18_Digit_Booking_ID__c\n    }\n  });\n\n}\n\nreturn output;"
