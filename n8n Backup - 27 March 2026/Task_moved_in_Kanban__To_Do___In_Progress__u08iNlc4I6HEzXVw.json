        "fromEmail": "notifications@lockated.com",
        "toEmail": "={{$json.project_manager_email}}",
        "subject": "=Task Started: {{$json.task_title}}\n\n",
        "html": "=<p>Dear {{$json.project_manager_firstname}} {{$json.project_manager_lastname}},</p>\n\n<p>The task <b>{{$json.task_title}}</b> has been moved to <b>In Progress</b>, indicating that work has commenced.</p>\n\n<p><b>Task Details</b><br>\n* Task Title: {{$json.task_title}}<br>\n* Started By: {{$json.started_by_firstname}} {{$json.started_by_lastname}}<br>\n* Current Status: {{$json.new_task_status}}<br>\n* Project: {{$json.project_title}}</p>\n\n<p>This update is shared for visibility and tracking purposes.</p>\n\n<p>Regards,<br>\nProject Monitoring Team</p>",
        "options": {}
      },
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [
        16,
        -192
      ],
