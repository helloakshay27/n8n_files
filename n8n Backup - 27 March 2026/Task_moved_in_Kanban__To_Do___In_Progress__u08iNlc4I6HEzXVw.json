      "webhookId": "ae807e0d-a553-41ea-9374-fe4557ded8be",
      "alwaysOutputData": true,
      "credentials": {
        "smtp": {
          "id": "e6BxRubia0RizPKp",
          "name": "Lockated Local SMTP"
        }
      }
    },
    {
      "parameters": {
        "respondWith": "allIncomingItems",
        "options": {}
      },
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.5,
      "position": [
        272,
        -80
      ],
      "id": "5e881cc4-3969-4bcc-ac83-8fb024e160b4",
      "name": "Respond to Webhook",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH latest_task_status AS (\n  SELECT\n    tsl.*,\n    ROW_NUMBER() OVER (\n      PARTITION BY tsl.task_management_id\n      ORDER BY tsl.created_at DESC\n    ) AS rn\n  FROM task_status_logs tsl\n  WHERE tsl.created_at >= UTC_TIMESTAMP() - INTERVAL 60 MINUTE\n)\n\nSELECT\n  lts.id                 AS task_status_log_id,\n  lts.status             AS new_task_status,\n  lts.created_at         AS status_changed_at,\n  lts.created_by_id      AS started_by,\n\n  su.firstname           AS started_by_firstname,\n  su.lastname            AS started_by_lastname,\n  su.email               AS started_by_email,\n\n  tm.id                  AS task_id,\n  tm.title               AS task_title,\n  tm.parent_id           AS parent_id,\n\n  pm.id                  AS project_id,\n  pm.title               AS project_title,\n\n  -- project manager\n  pm_owner.email         AS project_manager_email,\n  pm_owner.firstname     AS project_manager_firstname,\n  pm_owner.lastname      AS project_manager_lastname\n\nFROM latest_task_status lts\n\nJOIN task_managements tm\n  ON tm.id = lts.task_management_id\n\nJOIN project_managements pm\n  ON pm.id = tm.project_management_id\n\n-- project manager\nJOIN spree_users pm_owner\n  ON pm_owner.id = pm.owner_id\n\n-- started by user\nLEFT JOIN spree_users su\n  ON su.id = lts.created_by_id\n\nWHERE\n  lts.rn = 1\n  AND tm.parent_id IS NULL;",
        "options": {}
      },
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.5,
      "position": [
        -256,
        -224
      ],
      "id": "aac53951-3762-49f6-849d-1a0c2c73cd3f",
