      "name": "Schedule Trigger",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const YEARLY_VARIABLE = 120000; // dummy value\nconst MONTHLY_VARIABLE = YEARLY_VARIABLE / 12;\nconst BASE_REWARD = MONTHLY_VARIABLE * 0.01; // 1%\n\nconst output = [];\n\nfor (const item of $input.all()) {\n  const { task_id, user_id, hours_difference } = item.json;\n\n  let multiplier = 0;\n  let reason = '';\n\n  if (hours_difference >= 12) {\n    multiplier = 1.05;\n    reason = 'Completed 12 hours before deadline';\n  } else if (hours_difference >= 0) {\n    multiplier = 1.0;\n    reason = 'Completed on time';\n  } else if (hours_difference >= -12) {\n    multiplier = 0.75;\n    reason = 'Completed within 12 hours after deadline';\n  } else if (hours_difference >= -24) {\n    multiplier = 0.5;\n    reason = 'Completed within 24 hours after deadline';\n  } else {\n    continue; // no reward\n  }\n\n  const reward_amount = Math.round(BASE_REWARD * multiplier);\n\n  output.push({\n    json: {\n      task_id,\n      user_id,\n      reward_amount,\n      multiplier,\n      reason\n    }\n  });\n}\n\nreturn output;\n"
      },
      "type": "n8n-nodes-base.code",
