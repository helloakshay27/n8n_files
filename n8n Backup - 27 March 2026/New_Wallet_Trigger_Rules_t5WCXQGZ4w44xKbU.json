    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  t.id AS task_id,\n  t.responsible_person_id AS user_id,\n  t.target_date,\n  t.completed_at,\n\n  TIMESTAMPDIFF(\n    HOUR,\n    t.completed_at,\n    t.target_date\n  ) AS hours_difference\n\nFROM task_managements t\n\nWHERE\n  t.status = 'completed'\n\n  -- only recent completions\n  AND t.completed_at >= UTC_TIMESTAMP() - INTERVAL 24 HOUR\n\n  -- block already rewarded tasks\n  AND t.id NOT IN (\n    SELECT resource_id\n    FROM wallet_transactions\n    WHERE resource_type = 'TaskManagement'\n      AND point_type = 'task_reward'\n  );\n",
        "options": {}
