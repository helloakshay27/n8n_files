      "parameters": {
        "operation": "executeQuery",
        "query": "INSERT INTO wallet_transactions (\n  transaction_type,\n  amount,\n  booked_member_id,\n  wallet_id,\n  resource_type,\n  resource_id,\n  remarks,\n  earned_at,\n  point_type,\n  created_at,\n  updated_at\n)\nVALUES (\n  'credit',\n  {{ $json.reward_amount }},\n  {{ $json.user_id }},\n  (SELECT id FROM wallets WHERE user_id = {{ $json.user_id }} LIMIT 1),\n  'TaskManagement',\n  {{ $json.task_id }},\n  '{{ $json.reason }}',\n  UTC_TIMESTAMP(),\n  'task_reward',\n  UTC_TIMESTAMP(),\n  UTC_TIMESTAMP()\n);\n",
        "options": {}
