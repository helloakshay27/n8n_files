        "toEmail": "={{ $json.todo_owner_email }}",
        "subject": "= New To-Do Assigned – {{$json.todo_title}}\n",
        "emailFormat": "=html",
        "html": "=<p>Dear {{$json.todo_owner_firstname}} {{$json.todo_owner_lastname}},</p>\n\n<p>A new to-do item has been assigned to you.</p>\n\n<p>To-Do Details:<br>\n• Title: {{$json.todo_title}}<br>\n• Target Date: {{$json.target_date}}</p>\n\n<p>Please ensure timely completion.</p>\n\n<p>Regards,<br>\nTask System</p>",
        "options": {}
