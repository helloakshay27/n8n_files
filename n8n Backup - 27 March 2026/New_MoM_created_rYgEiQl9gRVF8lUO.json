      "id": "8e520f58-f2ff-41c5-baa1-e90ed0bdf021",
      "name": "Webhook",
      "webhookId": "e3596f6a-e006-4df1-9027-4172551df482",
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "fromEmail": "notificaions@lockated.com",
        "toEmail": "={{ $json.attendee_email}}",
        "subject": "= Minutes of Meeting Published – {{$json.title}}\n",
        "html": "=Dear {{$json.RecipientName}},\n\nThe Minutes of Meeting (MoM) for the meeting titled <b>{{$json.title}}</b>, held on {{$json.meeting_date}}, have been formally published.\n\nMeeting Summary:\n• Meeting Title: {{$json.title}}\n• Date & Time: {{$json.meeting_date}}\n• Organized By: {{$json.created_by_name}}\n\nPlease review key discussions, decisions taken, and assigned action items.\n\nAccess MoM:\n{{$json.mom_url}}\n\nRegards,\nMeeting Governance Office\n",
        "options": {}
      },
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [
        112,
        -48
      ],
      "id": "12f5dd7d-4cb0-4cb4-9166-016ab09d8588",
      "name": "Attendees",
      "webhookId": "eed3ea72-b72f-413b-b7b7-75ca5001f09e",
      "alwaysOutputData": true,
      "credentials": {
        "smtp": {
          "id": "m6pGNPu76sBcBXtf",
          "name": "Task Management SMTP Account"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  md.id            AS mom_id,\n  md.title         AS mom_title,\n  md.meeting_date,\n  md.created_at    AS mom_created_at,\n\n  ma.id            AS attendee_id,\n  ma.name          AS attendee_name,\n  su.email         AS attendee_email\n\nFROM mom_details md\n\nJOIN mom_attendees ma\n  ON ma.mom_detail_id = md.id\n  AND ma.attendees_type = 'FmUser'\n\nJOIN spree_users su\n  ON su.id = ma.attendees_id\n\nWHERE\n  md.created_at >= UTC_TIMESTAMP() - INTERVAL 60 MINUTE\n  AND su.email IS NOT NULL\n  AND su.email != '';\n",
        "options": {}
      },
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.5,
      "position": [
        -112,
        -144
      ],
      "id": "57ede7f4-0811-48a4-a092-c1ba07b53e39",
