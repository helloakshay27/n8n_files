    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  m.id                    AS milestone_id,\n  m.title                 AS milestone_title,\n  m.end_date              AS milestone_end_date,\n  m.start_date            AS milestone_start_date,\n\n  -- overdue calculation\n  DATEDIFF(CURDATE(), DATE(m.end_date)) AS overdue_days,\n\n  pm.id                   AS project_id,\n  pm.title                AS project_title,\n\n  -- milestone owner\n  mo.email                AS milestone_owner_email,\n  mo.firstname            AS milestone_owner_firstname,\n  mo.lastname             AS milestone_owner_lastname,\n\n  -- project manager\n  pmo.email               AS project_manager_email,\n  pmo.firstname           AS project_manager_firstname,\n  pmo.lastname            AS project_manager_lastname,\n\n  -- team member\n  tm.id                   AS team_user_id,\n  tm.firstname            AS team_user_first_name,\n  tm.lastname             AS team_user_last_name,\n  tm.email                AS team_user_email\n\nFROM milestones m\n\n-- milestone owner\nJOIN users mo\n  ON mo.id = m.owner_id\n\n-- project\nJOIN project_managements pm\n  ON pm.id = m.project_management_id\n\n-- project manager\nJOIN users pmo\n  ON pmo.id = pm.owner_id\n\n-- project team\nJOIN project_team_members ptm\n  ON ptm.project_team_id = pm.project_team_id\n\n-- team members\nJOIN users tm\n  ON tm.id = ptm.user_id\n\nWHERE\n  DATE(m.end_date) < CURDATE()\n  AND (m.status IS NULL OR m.status != 'Completed');",
        "options": {}
      },
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.5,
      "position": [
        -432,
        -160
      ],
      "id": "f3507fee-152a-45e4-9784-2a6dba68e791",
      "name": "Execute a SQL query",
      "alwaysOutputData": true,
      "credentials": {
        "mySql": {
          "id": "jlXMRexTLx3v7Dee",
          "name": "Task Management MySQL"
        }
      }
    },
    {
