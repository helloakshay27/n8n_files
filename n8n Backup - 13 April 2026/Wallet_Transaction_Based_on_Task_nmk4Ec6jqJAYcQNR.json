    {
      "parameters": {
        "jsCode": "const output = [];\n\nfor (const item of $input.all()) {\n  const { task_id, user_id, delay_days } = item.json;\n\n  let points = 0;\n  let remark = '';\n\n  if (delay_days <= 0) {\n    points = 100;\n    remark = 'Task completed on time';\n  } else if (delay_days === 1) {\n    points = 70;\n    remark = 'Task completed 1 day late';\n  } else if (delay_days === 2) {\n    points = 30;\n    remark = 'Task completed 2 days late';\n  } else {\n    continue; // no reward\n  }\n\n  output.push({\n    json: {\n      task_id,\n      user_id,\n      points,\n      remark\n    }\n  });\n}\n\nreturn output;\n"
      },
      "type": "n8n-nodes-base.code",
