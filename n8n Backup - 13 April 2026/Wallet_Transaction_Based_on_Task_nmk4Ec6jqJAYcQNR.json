    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  t.id AS task_id,\n  t.title AS task_title,\n  t.target_date,\n  t.completed_at,\n  t.responsible_person_id AS user_id,\n  DATEDIFF(DATE(t.completed_at), DATE(t.target_date)) AS delay_days\nFROM task_managements t\nWHERE\n  t.status = 'completed'\n  AND t.completed_at >= UTC_TIMESTAMP() - INTERVAL 10 MINUTE;\n\n\n/*SELECT\n  t.id AS task_id,\n  t.title AS task_title,\n  t.target_date,\n  t.completed_at,\n  t.responsible_person_id AS user_id,\n  DATEDIFF(DATE(t.completed_at), DATE(t.target_date)) AS delay_days\nFROM task_managements t\nWHERE\n  t.status = 'completed'\n  AND t.completed_at >= UTC_TIMESTAMP() - INTERVAL 500 MINUTE\n  AND t.id NOT IN (\n    SELECT resource_id\n    FROM wallet_transactions\n    WHERE resource_type = 'TaskManagement'\n      AND point_type = 'task_reward'\n  );*/",
        "options": {}
