    {
      "parameters": {
        "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"/>\n  <title>Content Review</title>\n  <link href=\"https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=DM+Mono:wght@400;500&display=swap\" rel=\"stylesheet\"/>\n  <style>\n    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }\n\n    :root {\n      --bg:        #F5F4F0;\n      --surface:   #FFFFFF;\n      --surface2:  #F9F8F5;\n      --border:    rgba(0,0,0,0.08);\n      --text-1:    #1A1916;\n      --text-2:    #5C5A54;\n      --text-3:    #9B9890;\n      --green-bg:  #E4F5EC;\n      --green-bd:  #34A85A;\n      --green-tx:  #1A5E34;\n      --radius-md: 10px;\n      --radius-lg: 16px;\n    }\n\n    body {\n      font-family: 'DM Sans', sans-serif;\n      background: var(--bg);\n      min-height: 100vh;\n      display: flex;\n      align-items: flex-start;\n      justify-content: center;\n      padding: 40px 16px;\n      color: var(--text-1);\n    }\n\n    .wrapper { \n      width: 100%; \n      max-width: 780px; \n    }\n\n    .card {\n      background: var(--surface);\n      border: 1px solid var(--border);\n      border-radius: var(--radius-lg);\n      overflow: hidden;\n      box-shadow: 0 2px 12px rgba(0,0,0,0.05);\n      animation: slideUp 0.6s ease-out;\n    }\n\n    /* Header */\n    .card-header {\n      padding: 28px;\n      text-align: center;\n      border-bottom: 1px solid var(--border);\n    }\n\n    .subject {\n      font-size: 28px;\n      font-weight: 500;\n      line-height: 1.4;\n      color: var(--text-1);\n      margin-bottom: 16px;\n    }\n\n    .status-badge {\n      display: inline-flex;\n      align-items: center;\n      gap: 8px;\n      background: var(--green-bg);\n      border: 1px solid var(--green-bd);\n      color: var(--green-tx);\n      padding: 10px 16px;\n      border-radius: 20px;\n      font-size: 14px;\n      font-weight: 500;\n      animation: slideDown 0.5s ease-out 0.1s both;\n    }\n\n    .status-badge svg {\n      width: 16px;\n      height: 16px;\n    }\n\n    /* Body */\n    .card-body {\n      padding: 28px;\n    }\n\n    .section-label {\n      font-size: 11px;\n      font-weight: 600;\n      color: var(--text-3);\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      margin-bottom: 12px;\n      margin-top: 24px;\n    }\n\n    .section-label:first-child {\n      margin-top: 0;\n    }\n\n    /* Content Block */\n    .content-block {\n      background: var(--surface2);\n      border: 1px solid var(--border);\n      border-radius: var(--radius-md);\n      padding: 22px 24px;\n      margin-bottom: 20px;\n      animation: slideUp 0.6s ease-out 0.2s both;\n    }\n\n    .content-block p {\n      font-size: 15px;\n      line-height: 1.8;\n      color: var(--text-1);\n      white-space: pre-wrap;\n      word-wrap: break-word;\n    }\n\n    /* Meta Information */\n    .meta-grid {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 20px;\n      margin-bottom: 20px;\n      animation: slideUp 0.6s ease-out 0.3s both;\n    }\n\n    .meta-item {\n      background: var(--surface2);\n      border: 1px solid var(--border);\n      border-radius: var(--radius-md);\n      padding: 16px;\n    }\n\n    .meta-label {\n      font-size: 11px;\n      font-weight: 600;\n      color: var(--text-3);\n      letter-spacing: 0.08em;\n      text-transform: uppercase;\n      display: block;\n      margin-bottom: 8px;\n    }\n\n    .meta-value {\n      font-size: 15px;\n      font-weight: 500;\n      color: var(--text-1);\n    }\n\n    .meta-subtext {\n      font-size: 13px;\n      color: var(--text-2);\n      margin-top: 4px;\n    }\n\n    .meta-grid-3 {\n      grid-template-columns: 1fr;\n    }\n\n    /* Footer */\n    .card-footer {\n      padding: 16px 28px;\n      border-top: 1px solid var(--border);\n      background: var(--surface2);\n      text-align: center;\n      font-size: 12px;\n      color: var(--text-3);\n      animation: slideUp 0.6s ease-out 0.4s both;\n    }\n\n    @keyframes slideUp {\n      from {\n        opacity: 0;\n        transform: translateY(20px);\n      }\n      to {\n        opacity: 1;\n        transform: translateY(0);\n      }\n    }\n\n    @keyframes slideDown {\n      from {\n        opacity: 0;\n        transform: translateY(-20px);\n      }\n      to {\n        opacity: 1;\n        transform: translateY(0);\n      }\n    }\n\n    @media (max-width: 520px) {\n      .subject { font-size: 22px; }\n      .card-header, .card-body { padding: 20px 18px; }\n      .meta-grid {\n        grid-template-columns: 1fr;\n      }\n    }\n  </style>\n</head>\n<body>\n<div class=\"wrapper\">\n\n  <div class=\"card\">\n\n    <!-- Header -->\n    <div class=\"card-header\">\n      <h1 class=\"subject\">Content Review</h1>\n      <div class=\"status-badge\">\n        <svg viewBox=\"0 0 16 16\" fill=\"none\">\n          <path d=\"M3 8L6.5 11.5L13 5\" stroke=\"currentColor\" stroke-width=\"1.8\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n        Approved\n      </div>\n    </div>\n\n    <!-- Body -->\n    <div class=\"card-body\">\n\n      <div class=\"section-label\">Content Reviewed</div>\n      <div class=\"content-block\">\n        <p>{{$json.Post_Content}}</p>\n      </div>\n\n      <div class=\"section-label\">Approver Details</div>\n      <div class=\"meta-grid\">\n        <div class=\"meta-item\">\n          <span class=\"meta-label\">Approved By</span>\n            <div class=\"meta-value\">\n            {{\n              $json.Action_Taken_by\n                .split(',')\n                .map(email => {\n                  let name = email.split('@')[0]; // remove domain\n                  return name\n                    .split('.')\n                    .map(part => part.charAt(0).toUpperCase() + part.slice(1))\n                    .join(' ');\n                })\n                .join(', ')\n            }}\n            </div>\n        </div>\n      </div>\n\n    </div>\n\n    <!-- Footer -->\n    <div class=\"card-footer\">\n      ✓ Review completed • Ready for publication\n    </div>\n\n  </div>\n\n</div>\n</body>\n</html>"
