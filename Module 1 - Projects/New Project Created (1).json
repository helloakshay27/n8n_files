    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  pm.id                AS project_id,\n  pm.title             AS project_title,\n  pm.project_team_id,\n  ptm.user_id          AS team_user_id,\n  u.firstname          AS first_name,\n  u.lastname           AS last_name,\n  u.email              AS team_user_email\nFROM project_managements pm\nJOIN project_team_members ptm\n  ON ptm.project_team_id = pm.project_team_id\nJOIN spree_users u\n  ON u.id = ptm.user_id\nWHERE pm.created_at >= UTC_TIMESTAMP() - INTERVAL 60 MINUTE;\n",
        "options": {}
