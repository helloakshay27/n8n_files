    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT \n  pm.*,\n  u.email AS owner_email\nFROM project_managements pm\nJOIN spree_users u\n  ON u.id = pm.owner_id\nWHERE\n  pm.created_at >= UTC_TIMESTAMP() - INTERVAL 60 MINUTE;\n",
