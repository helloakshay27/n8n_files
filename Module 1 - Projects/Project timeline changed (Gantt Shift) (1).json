    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  pm.id          AS project_id,\n  pm.title       AS project_title,\n  tm.id          AS team_user_id,\n  tm.firstname,\n  tm.lastname,\n  tm.email       AS team_user_email\nFROM project_managements pm\nJOIN project_team_members ptm\n  ON ptm.project_team_id = pm.project_team_id\nJOIN spree_users tm\n  ON tm.id = ptm.user_id\nWHERE\n  pm.updated_at >= UTC_TIMESTAMP() - INTERVAL 60 MINUTE\n  AND pm.updated_at > pm.created_at;\n",
        "options": {}
      },
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.5,
      "position": [
        192,
        -16
      ],
      "id": "8f910ee1-8b49-445b-b5ec-b8bd556d7928",
      "name": "Send Email to Project Manager",
      "alwaysOutputData": true,
      "credentials": {
        "mySql": {
          "id": "FGCPCtEG47rFAJ4J",
          "name": "New FM UAT Task Management Database"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  pm.id               AS project_id,\n  pm.title            AS project_title,\n  pm.start_date,\n  pm.end_date,\n  pm.updated_at       AS project_updated_at,\n\n  -- project manager (owner)\n  owner.email         AS project_manager_email,\n\n  -- team member\n  tm.id               AS team_user_id,\n  tm.firstname       AS team_user_first_name,\n  tm.lastname        AS team_user_last_name,\n  tm.email            AS team_user_email\n\nFROM project_managements pm\n\n-- project manager\nJOIN spree_users owner\n  ON owner.id = pm.owner_id\n\n-- project team members\nJOIN project_team_members ptm\n  ON ptm.project_team_id = pm.project_team_id\n\nJOIN spree_users tm\n  ON tm.id = ptm.user_id\n\nWHERE\n  pm.updated_at >= UTC_TIMESTAMP() - INTERVAL 60 MINUTE     -- updated within last 1 hour\n  AND pm.updated_at > pm.created_at               -- exclude newly created projects\n             -- avoid duplicate emails\n",
        "options": {}
      },
