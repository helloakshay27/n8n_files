    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  c.id                         AS comment_id,\n  c.body                       AS comment_body,\n  c.created_at                 AS comment_created_at,\n\n  t.id                         AS task_id,\n  t.title                      AS task_title,\n\n  owner.email                  AS task_owner_email,\n\n  u.id                         AS mentioned_user_id,\n  u.email                      AS mentioned_user_email\n\nFROM comments c\n\nJOIN task_managements t\n  ON t.id = c.commentable_id\n AND c.commentable_type = 'TaskManagement'\n\nJOIN spree_users owner\n  ON owner.id = t.responsible_person_id\n\nLEFT JOIN spree_users u\n  ON c.body REGEXP CONCAT('\\\\@\\\\[.*\\\\]\\\\(', u.id, '\\\\)')\n\nWHERE\n  c.created_at >= UTC_TIMESTAMP() - INTERVAL 180 MINUTE;\n",
        "options": {}
      },
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.5,
      "position": [
        -528,
        -272
      ],
      "id": "3fe706e1-fd20-4015-88d1-80e98e4d5ba5",
