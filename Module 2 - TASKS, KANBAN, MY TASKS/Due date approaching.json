    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  t.id                    AS task_id,\n  t.title                 AS task_title,\n  t.target_date           AS task_due_date,\n  t.status                AS task_status,\n\n  -- hours remaining\n  TIMESTAMPDIFF(\n    HOUR,\n    UTC_TIMESTAMP(),\n    t.target_date\n  )                       AS hours_remaining,\n\n  -- task owner\n  rp.email                AS task_owner_email,\n\n  -- project info (optional but useful in email)\n  pm.id                   AS project_id,\n  pm.title                AS project_title\n\nFROM task_managements t\n\n-- task owner\nJOIN spree_users rp\n  ON rp.id = t.responsible_person_id\n\n-- project\nJOIN project_managements pm\n  ON pm.id = t.project_management_id\n\nWHERE\n  t.status NOT IN ('completed', 'closed')\n  AND t.target_date > UTC_TIMESTAMP()                     -- not overdue\n  AND t.target_date <= UTC_TIMESTAMP() + INTERVAL 40 HOUR; -- due in next 24 hrs\n",
        "options": {}
      },
      "type": "n8n-nodes-base.mySql",
