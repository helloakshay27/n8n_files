    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  st.id AS subtask_id,\n  st.title AS subtask_title,\n  st.description,\n  st.status,\n  st.priority,\n  st.target_date AS subtask_target_date,\n  st.created_at AS subtask_created_at,\n  st.parent_id,\n  st.estimated_hour AS subtask_estimated_time,\n\n  CONVERT_TZ(st.expected_start_date, '+00:00', '+05:30') AS subtask_start_date,\n  CONVERT_TZ(st.target_date, '+00:00', '+05:30') AS subtask_end_date,\n\n  u.id AS responsible_person_id,\n  u.firstname AS responsible_person_first_name,\n  u.lastname AS responsible_person_last_name,\n  u.email AS responsible_person_email,\n\n  pt.id AS parent_task_id,\n  pt.title AS parent_task_title,\n\n  m.id AS milestone_id,\n  m.title AS milestone_title,\n\n  pm.id AS project_id,\n  pm.title AS project_title\n\nFROM task_managements st\n\nJOIN spree_users u\n  ON u.id = st.responsible_person_id\n\nLEFT JOIN task_managements pt\n  ON pt.id = st.parent_id\n\n-- milestone (can be NULL safely)\nLEFT JOIN milestones m\n  ON m.id = pt.milestone_id\n\n-- ✅ FIX: project directly from parent task\nLEFT JOIN project_managements pm\n  ON pm.id = pt.project_management_id\n\nWHERE\n  st.created_at >= UTC_TIMESTAMP() - INTERVAL 60 MINUTE\n  AND st.parent_id IS NOT NULL;",
        "options": {}
      },
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.5,
      "position": [
        96,
        208
      ],
      "id": "47695531-c3ae-417e-9441-460551453a0f",
