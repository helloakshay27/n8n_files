            "query": "SELECT\n  i.id            AS issue_id,\n  i.title         AS issue_title,\n  i.priority      AS issue_priority,\n  i.created_at    AS issue_created_at,\n\n  pm.id           AS project_id,\n  pm.title        AS project_title,\n\n  -- project manager\n  pm_owner.email  AS project_manager_email\n\nFROM issues i\n\nJOIN project_managements pm\n  ON pm.id = i.project_management_id\n\nJOIN spree_users pm_owner\n  ON pm_owner.id = pm.owner_id\n\nWHERE\n  i.created_at >= UTC_TIMESTAMP() - INTERVAL 60 MINUTE\n  AND LOWER(i.priority) IN ('high', 'urgent');\n",
