      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT DISTINCT\n  m.id          AS milestone_id,\n  m.title       AS milestone_title,\n\n  CONVERT_TZ(m.created_at, '+00:00', '+05:30') AS milestone_created_at,\n  CONVERT_TZ(m.start_date, '+00:00', '+05:30') AS milestone_start_date,\n  CONVERT_TZ(m.end_date, '+00:00', '+05:30')   AS milestone_end_date,\n\n  pm.id         AS project_id,\n  pm.title      AS project_title,\n\n  mo.email      AS milestone_owner_email,\n  mo.firstname  AS milestone_owner_firstname,\n  mo.lastname   AS milestone_owner_lastname,\n\n  pmo.email     AS project_manager_email,\n  pmo.firstname AS project_manager_firstname,\n  pmo.lastname  AS project_manager_lastname\n\nFROM milestones m\n\nJOIN spree_users mo\n  ON mo.id = m.owner_id\n\nJOIN project_managements pm\n  ON pm.id = m.project_management_id\n\nJOIN spree_users pmo\n  ON pmo.id = pm.owner_id\n\nWHERE\n  m.created_at >= UTC_TIMESTAMP() - INTERVAL 10 MINUTE\n  AND pmo.organization_id IN (13, 14, 59, 84);",
          "options": {}
        },
        "type": "n8n-nodes-base.mySql",
        "typeVersion": 2.5,
        "position": [
          -416,
          -128
        ],
