        "parameters": {
          "jsCode": "const output = [];\n\nfor (const item of items) {\n\n  output.push({\n    json: {\n      id: item.json.ID,\n      customer_code: item.json.customer_id,\n      customer_mobile: item.json.customer_mobile,\n      customer_name: item.json.customer_name,\n      amount: 1000,\n      remarks: \"Booking within 30 days of Site Visit\",\n      transaction_note: \"Credit points for booking within 30 days of Site Visit\",\n      payment_mode: \"cash\",\n      topup_by: \"automation\",\n      booking_date: item.json.Booking_Date,\n      sv_date: item.json.SV_Date__c,\n      booking_id: item.json.X18_Digit_Booking_ID__c,\n      today_delta_additions: item.json.today_delta_additions\n    }\n  });\n\n}\n\nreturn output;"
        },
