      {
        "parameters": {
          "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const data = item.json;\n\n  const content = (data['Posting Content'] || '').trim();\n  const hashtags = (data['Hashtags'] || '').trim();\n  const emojis = (data['Emojis'] || '').trim();\n\n  let postText = content;\n  if (hashtags || emojis) {\n    postText += '\\n\\n';\n    if (emojis) postText += emojis + ' ';\n    if (hashtags) postText += hashtags;\n  }\n\n  const imageUrl = (data['Image URL'] || '').trim();\n  const hasImage = imageUrl !== '' && imageUrl !== '(Leave blank for now)';\n\n  const linkedInBody = JSON.stringify({\n    author: \"urn:li:person:U8RrGddXCf\",\n    commentary: postText.trim(),\n    visibility: \"PUBLIC\",\n    distribution: {\n      feedDistribution: \"MAIN_FEED\",\n      targetEntities: [],\n      thirdPartyDistributionChannels: []\n    },\n    lifecycleState: \"PUBLISHED\",\n    isReshareDisabledByAuthor: false\n  });\n\n  return {\n    json: {\n      ...data,\n      composedText: postText.trim(),\n      imageUrl: hasImage ? imageUrl : null,\n      hasImage: hasImage,\n      rowNumber: data['#'],\n      linkedInBody: linkedInBody\n    }\n  };\n});"
        },
        "id": "987783e3-09e4-4bbb-b77c-e70720245252",
        "name": "Compose Post Text",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          -2512,
          112
        ]
      },
      {
        "parameters": {
