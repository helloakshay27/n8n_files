        "parameters": {
          "jsCode": "const items = $input.all();\n\nreturn items.map(item => {\n  const postUrl = item.json?.id \n    ? `https://www.linkedin.com/feed/update/${item.json.id}/` \n    : '';\n\n  return {\n    json: {\n      ...item.json,\n      resolvedPostUrl: postUrl,\n      publishedDate: $now.toFormat('yyyy-MM-dd')\n    }\n  };\n});"
