    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  pm.id          AS project_id,\n  pm.title       AS project_title,\n  tm.id          AS team_user_id,\n  tm.firstname,\n  tm.lastname,\n  tm.email       AS team_user_email\nFROM project_managements pm\nJOIN project_team_members ptm\n  ON ptm.project_team_id = pm.project_team_id\nJOIN spree_users tm\n  ON tm.id = ptm.user_id\nWHERE\n  pm.updated_at >= UTC_TIMESTAMP() - INTERVAL 60 MINUTE\n  AND pm.updated_at > pm.created_at;\n",
        "options": {}
      },
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.5,
      "position": [
        192,
        -16
      ],
      "id": "8f910ee1-8b49-445b-b5ec-b8bd556d7928",
