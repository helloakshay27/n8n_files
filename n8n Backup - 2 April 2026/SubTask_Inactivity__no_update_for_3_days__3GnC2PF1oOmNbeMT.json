    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  -- =========================\n  -- SUBTASK\n  -- =========================\n  t.id            AS subtask_id,\n  t.title         AS subtask_name,\n  t.description   AS subtask_description,\n  t.status        AS subtask_status,\n  t.priority      AS subtask_priority,\n  t.target_date   AS subtask_target_date,\n  t.created_at    AS subtask_created_at,\n  t.updated_at    AS subtask_last_updated,\n  CONVERT_TZ(t.expected_start_date, '+00:00', '+05:30') AS subtask_start_on,\n  CONVERT_TZ(t.target_date, '+00:00', '+05:30') AS subtask_end_on,\n\n  -- Responsible person (subtask owner)\n  rp.id           AS responsible_person_id,\n  rp.firstname    AS responsible_person_first_name,\n  rp.lastname     AS responsible_person_last_name,\n  rp.email        AS responsible_person_email,\n\n  -- =========================\n  -- PARENT TASK\n  -- =========================\n  pt.id           AS parent_task_id,\n  pt.title        AS parent_task_title,\n\n  -- =========================\n  -- PROJECT\n  -- =========================\n  pm.id           AS project_id,\n  pm.title        AS project_title,\n\n  -- =========================\n  -- PROJECT MANAGER\n  -- =========================\n  pmo.id          AS manager_id,\n  pmo.firstname   AS manager_first_name,\n  pmo.lastname    AS manager_last_name,\n  pmo.email       AS manager_email,\n\n  -- =========================\n  -- MILESTONE\n  -- =========================\n  m.id            AS milestone_id,\n  m.title         AS milestone_title,\n\n  -- =========================\n  -- OBSERVERS\n  -- =========================\n  GROUP_CONCAT(DISTINCT obs.id) AS observer_ids,\n  GROUP_CONCAT(DISTINCT obs.firstname) AS observer_first_names,\n  GROUP_CONCAT(DISTINCT obs.lastname) AS observer_last_names,\n  GROUP_CONCAT(DISTINCT obs.email) AS observer_emails\n\nFROM task_managements t\n\n-- Subtask responsible person\nJOIN spree_users rp\n  ON rp.id = t.responsible_person_id\n\n-- Project via subtask\nJOIN project_managements pm\n  ON pm.id = t.project_management_id\n\n-- Project manager\nJOIN spree_users pmo\n  ON pmo.id = pm.owner_id\n\n-- Parent task\nLEFT JOIN task_managements pt\n  ON pt.id = t.parent_id\n\n-- Milestone via parent task\nLEFT JOIN milestones m\n  ON m.id = pt.milestone_id\n\n-- Observers\nLEFT JOIN task_users tu\n  ON tu.task_id = t.id\n  AND tu.user_type = 'observer'\n  AND tu.active = 1\n\nLEFT JOIN spree_users obs\n  ON obs.id = tu.user_id\n\nWHERE\n  t.status IN ('open', 'in_progress', 'on_hold', 'overdue', 'started')\n  AND t.updated_at <= UTC_TIMESTAMP() - INTERVAL 60 MINUTE\n  AND t.active = 1\n  AND t.parent_id IS NOT NULL\n\nGROUP BY t.id;",
        "options": {}
      },
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.5,
      "position": [
        288,
        96
      ],
      "id": "195c31f4-da34-4dd5-956d-cbcf35c9facc",
