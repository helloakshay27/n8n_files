    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  mt.id                 AS mom_task_id,\n  mt.description        AS action_description,\n  mt.target_date,\n  mt.status             AS action_status,\n  mt.created_at         AS action_created_at,\n\n  md.id                 AS mom_id,\n  md.title              AS mom_title,\n  md.meeting_date,\n\n  su.id                 AS responsible_user_id,\n  su.firstname          AS responsible_user_first_name,\n  su.lastname           AS responsible_user_last_name,\n  su.email              AS responsible_user_email\n\nFROM mom_tasks mt\n\nJOIN mom_details md\n  ON md.id = mt.mom_detail_id\n\nJOIN spree_users su\n  ON su.id = mt.responsible_person_id\n\nWHERE\n  mt.created_at >= UTC_TIMESTAMP() - INTERVAL 60 MINUTE\n  AND su.email IS NOT NULL\n  AND su.email != '';\n",
        "options": {}
      },
