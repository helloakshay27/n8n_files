    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  c.id                         AS comment_id,\n  c.body                       AS comment_body,\n  c.created_at                 AS comment_created_at,\n  c.commentor_id               AS commented_by_id,\n\n  commenter.firstname          AS commented_by_firstname,\n  commenter.lastname           AS commented_by_lastname,\n  commenter.email              AS commented_by_email,\n\n  t.id                         AS task_id,\n  t.title                      AS task_title,\n\n  owner.email                  AS task_owner_email,\n\n  u.id                         AS mentioned_user_id,\n  u.email                      AS mentioned_user_email\n\nFROM comments c\n\nJOIN task_managements t\n  ON t.id = c.commentable_id\n AND c.commentable_type = 'TaskManagement'\n\nJOIN spree_users owner\n  ON owner.id = t.responsible_person_id\n\n-- commenter\nLEFT JOIN spree_users commenter\n  ON commenter.id = c.commentor_id\n\n-- mentioned users\nLEFT JOIN spree_users u\n  ON c.body REGEXP CONCAT('\\\\@\\\\[.*\\\\]\\\\(', u.id, '\\\\)')\n\nWHERE\n  c.created_at >= UTC_TIMESTAMP() - INTERVAL 180 MINUTE;",
        "options": {}
      },
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.5,
      "position": [
