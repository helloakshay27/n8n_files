    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nconst base = items[0].json;\n\nconst mentionedEmails = items\n  .map(i => i.json.mentioned_user_email)\n  .filter(Boolean);\n\nconst recipients = [\n  base.task_owner_email,\n  ...mentionedEmails\n];\n\nreturn [{\n  json: {\n    task_id: base.task_id,\n    task_title: base.task_title,\n    comment_body: base.comment_body,\n    commented_by_firstname: base.commented_by_firstname,\n    commented_by_lastname: base.commented_by_lastname,\n    all_recipients: [...new Set(recipients)]\n  }\n}];\n"
      },
