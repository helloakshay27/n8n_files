    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\n// first item always contains task data\nconst taskData = items[0].json;\n\n// collect mentioned user emails (if any)\nconst mentionedEmails = items\n  .map(i => i.json.email)\n  .filter(email => email && email.includes('@')); // removes null\n\n// build recipient list\nconst recipients = [\n  taskData.task_owner_email,\n  ...mentionedEmails\n];\n\n// remove nulls + duplicates\nconst uniqueRecipients = [...new Set(recipients.filter(Boolean))];\n\nreturn [{\n  json: {\n    task_id: taskData.task_id,\n    task_title: taskData.task_title,\n    comment_body: taskData.comment_body,\n    all_recipients: uniqueRecipients\n  }\n}];\n"
      },
