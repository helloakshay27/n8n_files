    {
      "parameters": {
        "fromEmail": "notifications@lockated.com",
        "toEmail": "={{$json.responsible_person_email}}\n",
        "subject": "=New Task Assigned: {{$json.task_title}}\n\n\n",
        "html": "=Dear {{$json.responsible_person_first_name}}{{$json.responsible_person_last_name}},\n\nYou have been assigned a new task requiring your attention.\n\nTask Details\n* Task Title: {{$json.task_title}}\n* Description: {{$json.description}}\n* Status: {{$json.status}}\n* Priority: {{$json.priority}}\n* Assigned To: {{$json.responsible_person_first_name}}{{$json.responsible_person_first_name}}\n\nPlease begin execution and keep the task status updated.\n\nRegards,\nTask Management System\n",
        "options": {}
      },
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
