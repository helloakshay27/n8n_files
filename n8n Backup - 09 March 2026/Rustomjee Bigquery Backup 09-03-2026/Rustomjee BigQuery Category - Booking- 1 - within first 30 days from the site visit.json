        "sqlQuery": "SELECT\n  KUNNR AS customer_id,\n  COALESCE(Account_Mobile_Number__c, Account_Mobile_1__c, Mobile_Number__c, PrimaryMobileNumber__c) AS customer_mobile,\n  CONCAT(First_Name__c, ' ', Last_Name__c) AS customer_name,\n  Booking_Date,\n  SV_Date__c,\n  Opportunity_ID__c,\n  X18_Digit_Booking_ID__c,\n  Project_Text__c\nFROM `powerbi-implementation.dataWarehouse_prod.sales_booking`\nWHERE Booking_Date IS NOT NULL\nAND SV_Date__c IS NOT NULL\nAND Status__c = 'Processed'\nAND DATE_DIFF(\n      DATE(Booking_Date),\n      DATE(SV_Date__c),\n      DAY\n    ) BETWEEN 0 AND 30\nAND COALESCE(Account_Mobile_Number__c, Account_Mobile_1__c, Mobile_Number__c, PrimaryMobileNumber__c) IS NOT NULL",
