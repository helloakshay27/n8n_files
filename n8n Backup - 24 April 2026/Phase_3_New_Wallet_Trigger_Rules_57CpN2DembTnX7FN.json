        "name": "Schedule Trigger",
        "alwaysOutputData": true
      },
      {
        "parameters": {
          "jsCode": "const map = {};\n\nfor (const item of $input.all()) {\n  const { user_id, status } = item.json;\n\n  if (!map[user_id]) {\n    map[user_id] = {\n      user_id,\n      total: 0,\n      completed: 0\n    };\n  }\n\n  map[user_id].total++;\n\n  if (status === 'completed') {\n    map[user_id].completed++;\n  }\n}\n\nconst output = [];\n\nfor (const userId in map) {\n  const u = map[userId];\n\n  const ratio =\n    u.total > 0 ? u.completed / u.total : 0;\n\n  output.push({\n    json: {\n      user_id: u.user_id,\n      total_todos: u.total,\n      completed_todos: u.completed,\n      ratio: ratio\n    }\n  });\n}\n\nreturn output;\n"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          -544,
          112
        ],
        "id": "bf301ebe-9f00-4dac-ae52-7305651194d3",
        "name": "Code in JavaScript",
        "alwaysOutputData": true
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT\n  t.id AS todo_id,\n  t.user_id,\n  t.status,\n  DATE(t.created_at) AS todo_date\nFROM todos t\nWHERE DATE(t.created_at) = CURDATE();\n",
          "options": {}
        },
