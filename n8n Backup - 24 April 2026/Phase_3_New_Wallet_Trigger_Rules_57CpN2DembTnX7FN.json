        "parameters": {
          "operation": "executeQuery",
          "query": "INSERT INTO wallet_transactions (\n  transaction_type,\n  amount,\n  booked_member_id,\n  wallet_id,\n  resource_type,\n  resource_id,\n  remarks,\n  earned_at,\n  point_type,\n  created_at,\n  updated_at\n)\nVALUES (\n  'credit',\n  778,\n  87989,\n  (\n    SELECT id\n    FROM wallets\n    WHERE user_id = 87989\n    LIMIT 1\n  ),\n  'Todo',\n  CURDATE(),\n  'Daily To-Do completion score: 78%',\n  UTC_TIMESTAMP(),\n  'daily_todo',\n  UTC_TIMESTAMP(),\n  UTC_TIMESTAMP()\n);\n",
