        "parameters": {
          "jsCode": "const DAILY_TODO_POOL = 1000;\n\nreturn $input.all().map(item => {\n  const { user_id, ratio } = item.json;\n\n  const points = Math.round(DAILY_TODO_POOL * ratio);\n\n  return {\n    json: {\n      user_id,\n      points,\n      remark: `Daily To-Do completion score: ${Math.round(ratio * 100)}%`\n    }\n  };\n});\n\n// const DAILY_TODO_POOL = 1000;\n\n// return $input.all().map(item => {\n//   const { user_id, ratio } = item.json;\n\n//   const points = Math.round(DAILY_TODO_POOL * ratio);\n\n//   return {\n//     json: {\n//       user_id,\n//       reward_date: new Date().toISOString().slice(0, 10), // YYYY-MM-DD\n//       points,\n//       remark: `Daily To-Do completion score: ${Math.round(ratio * 100)}%`\n//     }\n//   };\n// });\n\n\n"
