      {
        "parameters": {
          "jsCode": "// return items\n//   .map(item => {\n//     const demandDate = new Date(item.json.FKDAT);\n//     const paymentDate = new Date(item.json.PAY_DATE);\n\n//     const diffDays = (paymentDate - demandDate) / (1000 * 60 * 60 * 24);\n\n//     if (diffDays >= 0 && diffDays <= 5) {\n//       return {\n//         json: {\n//           customer_id: item.json.KUNNR,\n//           demand_date: item.json.FKDAT,\n//           payment_date: item.json.PAY_DATE,\n//           diff_days: diffDays,\n//           points: 6000,\n//           rule: \"Paid within 5 days\"\n//         }\n//       };\n//     }\n\n//     return null;\n//   })\n//   .filter(Boolean);\n\nreturn items\n  .map(item => {\n    const demandDate = new Date(item.json.FKDAT);\n    const paymentDate = new Date(item.json.PAY_DATE);\n\n    const diffDays = (paymentDate - demandDate) / (1000 * 60 * 60 * 24);\n\n    if (diffDays >= 0 && diffDays <= 5) {\n\n      const customerId = item.json.KUNNR;\n      const rule = \"Paid within 5 days\";\n      const paymentDateStr = item.json.PAY_DATE;\n      const today_delta_additions = item.json.today_delta_additions;\n\n      const reference_id = `${customerId}_6000_${paymentDateStr}`;\n\n      return {\n        json: {\n          customer_id: customerId,\n          mobile_number: item.json.MOBILE || null,\n\n          demand_date: item.json.FKDAT,\n          payment_date: paymentDateStr,\n          diff_days: diffDays,\n\n          points: 6000,\n          rule: rule,\n          today_delta_additions:today_delta_additions,\n\n          transaction_type: \"CREDIT\",\n\n          reference_id: reference_id,\n\n          workflow_name: \"wallet_incentive_workflow\",\n          execution_id: $execution.id,\n\n          request_payload: {\n            customer_id: customerId,\n            demand_date: item.json.FKDAT,\n            payment_date: paymentDateStr,\n            diff_days: diffDays,\n            points: 6000,\n            rule: rule\n          }\n        }\n      };\n    }\n\n    return null;\n  })\n  .filter(Boolean);"
        },
