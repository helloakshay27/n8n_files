      {
        "parameters": {
          "jsCode": "return items.map(item => {\n  return {\n    json: {\n      customer_id: item.json.ID,\n      customer_mobile: item.json.customer_mobile,\n      email: item.json.Account_Email__c,\n      customer_unique_key: `${item.json.customer_mobile}_${item.json.Account_Email__c}`,\n      opportunity_id: item.json.Id,\n      today_date: item.json.today_delta_additions,\n      points: 1000,\n      rule: \"OpportunityClosedLostSurvey\",\n      today_delta_additions: item.json.today_delta_additions\n    }\n  };\n});"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          320,
          48
        ],
        "id": "d1267ba5-7cbd-4db6-9213-49327b2b2da4",
        "name": "Code in JavaScript3",
        "alwaysOutputData": true
      },
      {
        "parameters": {
          "authentication": "serviceAccount",
          "projectId": {
            "__rl": true,
            "value": "powerbi-implementation",
            "mode": "list",
            "cachedResultName": "PowerBI Implementation",
            "cachedResultUrl": "https://console.cloud.google.com/bigquery?project=powerbi-implementation"
          },
          "sqlQuery": "SELECT \n  ID,\n  Account_Email__c,\n\n  -- ✅ Single unified mobile field\n  REGEXP_REPLACE(\n    COALESCE(\n      Account_Mobile_1__c,\n      Account_Mobile_2__c,\n      Account_Mobile_Number__c\n    ),\n    r'[^0-9]',\n    ''\n  ) AS customer_mobile,\n\n  today_delta_additions\n\nFROM `powerbi-implementation.dataWarehouse_prod.opportunity_survey`\n\nWHERE \n  Survey_Name__c = 'OpportunityClosedLostSurvey'\n  AND Status__c = 'Completed'\n  --AND StageName IN ('Closed Won', 'Booking In Process', 'Booking Confirmed', 'Closed Won', 'BookingInProcess', 'BookingConfirmed') --\n  AND today_delta_additions = CURRENT_DATE()\n\n  -- ✅ Ensure at least one mobile exists\n  AND (\n    Account_Mobile_1__c IS NOT NULL OR\n    Account_Mobile_2__c IS NOT NULL OR\n    Account_Mobile_Number__c IS NOT NULL\n  )\n\n  -- ✅ Ensure email exists\n  AND Account_Email__c IS NOT NULL",
          "options": {}
        },
        "type": "n8n-nodes-base.googleBigQuery",
        "typeVersion": 2.1,
        "position": [
          -16,
          -32
        ],
        "id": "499a4b8a-27ff-4684-a7be-f0fe4b2d9cdb",
