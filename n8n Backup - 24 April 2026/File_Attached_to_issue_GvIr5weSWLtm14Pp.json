      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT\n  i.*,\n  i.id                    AS issue_id,\n  i.title                 AS issue_title,\n  CONVERT_TZ(i.created_at, '+00:00', '+05:30')           AS issue_created_at,\n  i.end_date              AS issue_end_date,\n  i.status                AS issue_status,\n  i.priority              AS issue_priority,\n\n  pm.id                   AS project_id,\n  pm.title                AS project_title,\n\n  -- issue owner\n  io.email                AS issue_owner_email,\n  io.firstname            AS issue_owner_firstname,\n  io.lastname             AS issue_owner_lastname,\n\n  -- project manager\n  pmo.email               AS project_manager_email,\n  pmo.firstname           AS project_manager_firstname,\n  pmo.lastname            AS project_manager_lastname,\n\n  -- created by user\n  cb.firstname            AS created_by_firstname,\n  cb.lastname             AS created_by_lastname,\n\n  -- linked task info\n  t.id                     AS task_id,\n  t.title                  AS task_title,\n\n  -- milestone info\n  m.title                  AS milestone_title,\n\n  -- attachment info\n  af.id                     AS attachment_id,\n  af.document_file_name      AS file_name,\n  af.document_content_type   AS file_type,\n  af.created_at              AS file_added_at\n\nFROM issues i\n\n-- issue owner\nJOIN spree_users io\n  ON io.id = i.responsible_person_id\n\n-- project\nJOIN project_managements pm\n  ON pm.id = i.project_management_id\n\n-- project manager\nJOIN spree_users pmo\n  ON pmo.id = pm.owner_id\n\n-- created by user\nLEFT JOIN spree_users cb\n  ON cb.id = i.created_by_id\n\n-- linked task from issue.task_management_id\nLEFT JOIN task_managements t\n  ON t.id = i.task_management_id\n\n-- milestone info\nLEFT JOIN milestones m\n  ON m.id = i.milestone_id\n\n-- issue attachments (only issues with attachments)\nINNER JOIN attachfiles af\n  ON af.relation_id = i.id\n AND af.relation = 'Issue'\n AND af.active = 1\n\nWHERE\n  i.created_at >= UTC_TIMESTAMP() - INTERVAL 60 MINUTE;",
          "options": {}
        },
        "type": "n8n-nodes-base.mySql",
        "typeVersion": 2.5,
        "position": [
          -240,
