        "credentials": {
          "smtp": {
            "id": "m6pGNPu76sBcBXtf",
            "name": "Task Management SMTP Account"
          }
        }
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT\n  o.id            AS opportunity_id,\n  o.title         AS opportunity_title,\n  o.status        AS opportunity_status,\n  o.created_at    AS opportunity_created_at,\n\n  -- opportunity owner\n  owner.email     AS opportunity_owner_email\n\nFROM opportunities o\n\nJOIN spree_users owner\n  ON owner.id = o.responsible_person_id\n\nWHERE\n  o.created_at >= UTC_TIMESTAMP() - INTERVAL 60 MINUTE\n  AND o.active = 1;\n",
          "options": {}
        },
