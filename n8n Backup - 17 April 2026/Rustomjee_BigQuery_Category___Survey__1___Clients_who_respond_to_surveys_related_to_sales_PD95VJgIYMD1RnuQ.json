      {
        "parameters": {
          "jsCode": "const output = [];\n\nfor (const item of items) {\n\n  output.push({\n    json: {\n      customer_id: item.json.customer_id,\n      customer_mobile: item.json.customer_mobile,\n      customer_name: item.json.customer_name,\n      points: 1000,\n      reason: \"Booking within 30 days of Site Visit\",\n      booking_date: item.json.Booking_Date,\n      sv_date: item.json.SV_Date__c,\n      booking_id: item.json.X18_Digit_Booking_ID__c\n    }\n  });\n\n}\n\nreturn output;"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          320,
          48
        ],
        "id": "d1267ba5-7cbd-4db6-9213-49327b2b2da4",
        "name": "Code in JavaScript3",
        "alwaysOutputData": true
      },
      {
        "parameters": {
          "authentication": "serviceAccount",
          "projectId": {
            "__rl": true,
            "value": "powerbi-implementation",
            "mode": "list",
            "cachedResultName": "PowerBI Implementation",
            "cachedResultUrl": "https://console.cloud.google.com/bigquery?project=powerbi-implementation"
          },
          "sqlQuery": "SELECT\n  KUNNR AS customer_id,\n  COALESCE(Account_Mobile_Number__c, Account_Mobile_1__c, Mobile_Number__c, PrimaryMobileNumber__c) AS customer_mobile,\n  CONCAT(First_Name__c, ' ', Last_Name__c) AS customer_name,\n  Booking_Date,\n  SV_Date__c,\n  Opportunity_ID__c,\n  X18_Digit_Booking_ID__c,\n  Project_Text__c\nFROM `powerbi-implementation.dataWarehouse_prod.sales_booking`\nWHERE Booking_Date IS NOT NULL\nAND SV_Date__c IS NOT NULL\nAND Status__c = 'Processed'\nAND DATE_DIFF(\n      DATE(Booking_Date),\n      DATE(SV_Date__c),\n      DAY\n    ) BETWEEN 0 AND 30\nAND COALESCE(Account_Mobile_Number__c, Account_Mobile_1__c, Mobile_Number__c, PrimaryMobileNumber__c) IS NOT NULL",
          "options": {}
        },
        "type": "n8n-nodes-base.googleBigQuery",
        "typeVersion": 2.1,
        "position": [
          -16,
          -32
        ],
