      {
        "parameters": {
          "jsCode": "return items\n\n  .map(item => {\n\n    const data = item.json;\n\n    // Pick first available mobile\n    const customer_mobile =\n      data.Account_Mobile_1__c ||\n      data.Account_Mobile_Number__c ||\n      null;\n\n    // Validations\n    if (\n\n      data.Launch_Category__c !== \"EOI\" ||\n\n      data.StageName !== \"Booking confirmed\" ||\n\n      !data.Booking__c ||\n\n      !customer_mobile\n\n    ) {\n      return null;\n    }\n\n    return {\n      json: {\n\n        customer_code:\n          data.KUNNR,\n\n        customer_mobile:\n          customer_mobile,\n\n        customer_name:\n          data.Name,\n\n        email:\n          data.Account_Email__c,\n\n        amount: 1000,\n\n        remarks:\n          \"EOI Booking Reward\",\n\n        transaction_note:\n          \"EOI Booking\",\n\n        payment_mode: \"cash\",\n\n        topup_by: \"automation\",\n\n        booking_reference:\n          data.Booking__c,\n\n        today_delta_additions:\n          data.today_delta_additions\n      }\n    };\n\n  })\n\n  .filter(Boolean);"
        },
