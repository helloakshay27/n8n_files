      {
        "parameters": {
          "jsCode": "const allowedStages = [\n  \"Closed Won\",\n  \"Booking In Process\",\n  \"Booking Confirmed\",\n  \"ClosedWon\",\n  \"BookingInProcess\",\n  \"BookingConfirmed\"\n];\n\nreturn items\n\n  .map(item => {\n\n    const data = item.json;\n\n    // Pick first available mobile\n    const rawMobile =\n      data.Account_Mobile_1__c ||\n      data.Account_Mobile_2__c ||\n      data.Account_Mobile_Number__c ||\n      null;\n\n    // Remove non-numeric chars\n    const customer_mobile =\n      rawMobile\n        ? String(rawMobile).replace(/\\D/g, \"\")\n        : null;\n\n    // Validations\n    if (\n      data.Survey_Name__c !==\n        \"OpportunityClosedWonLostSurvey\" ||\n\n      data.Status__c !== \"Completed\" ||\n\n      !allowedStages.includes(data.StageName) ||\n\n      !customer_mobile ||\n\n      !data.Account_Email__c\n    ) {\n      return null;\n    }\n\n    return {\n      json: {\n\n        customer_code:\n          data.KUNNR,\n\n        customer_mobile:\n          customer_mobile,\n\n        email:\n          data.Account_Email__c,\n\n        customer_unique_key:\n          `${customer_mobile}_${data.Account_Email__c}`,\n\n        opportunity_id:\n          data.KUNNR,\n\n        today_date:\n          data.today_delta_additions,\n\n        amount: 1000,\n\n        remarks:\n          \"OpportunityClosedLostSurvey\",\n\n        transaction_note:\n          \"Credit point for taking survey\",\n\n        payment_mode: \"cash\",\n\n        topup_by: \"automation\",\n\n        today_delta_additions:\n          data.today_delta_additions\n      }\n    };\n\n  })\n\n  .filter(Boolean);"
        },
