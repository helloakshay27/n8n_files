          "sqlQuery": "SELECT \n  ID,\n  Account_Email__c,\n\n  -- ✅ Single unified mobile field\n  REGEXP_REPLACE(\n    COALESCE(\n      Account_Mobile_1__c,\n      Account_Mobile_2__c,\n      Account_Mobile_Number__c\n    ),\n    r'[^0-9]',\n    ''\n  ) AS customer_mobile,\n\n  today_delta_additions\n\nFROM `powerbi-implementation.dataWarehouse_prod.opportunity_survey`\n\nWHERE \n  Survey_Name__c = 'OpportunityClosedWonLostSurvey'\n  AND Status__c = 'Completed'\n  AND StageName IN ('Closed Won', 'Booking In Process', 'Booking Confirmed', 'ClosedWon', 'BookingInProcess', 'BookingConfirmed')\n  -- AND today_delta_additions = CURRENT_DATE()\n\n  -- ✅ Ensure at least one mobile exists\n  AND (\n    Account_Mobile_1__c IS NOT NULL OR\n    Account_Mobile_2__c IS NOT NULL OR\n    Account_Mobile_Number__c IS NOT NULL\n  )\n\n  -- ✅ Ensure email exists\n  AND Account_Email__c IS NOT NULL",
          "options": {}
        },
