      {
        "parameters": {
          "jsCode": "return items\n\n  .map(item => {\n\n    const data = item.json;\n\n    // Valid statuses only\n    if (\n      ![\"Booked\", \"Processed\"]\n        .includes(data.Status__c)\n    ) {\n      return null;\n    }\n\n    // Pick first available mobile\n    const mobile =\n      data.Account_Mobile_Number__c ||\n      data.Account_Mobile_1__c ||\n      data.Mobile_Number__c ||\n      null;\n\n    // Skip no mobile\n    if (!mobile) {\n      return null;\n    }\n\n    // Booking date required\n    if (!data.Booking_Date) {\n      return null;\n    }\n\n    const customer_id =\n      data.KUNNR || mobile;\n\n    return {\n      json: {\n\n        id: data.ID,\n\n        today_delta_additions:\n          data.today_delta_additions,\n\n        customer_id:\n          customer_id,\n\n        mobile:\n          mobile,\n\n        booking_date:\n          data.Booking_Date,\n\n        first_name:\n          data.First_Name__c,\n\n        last_name:\n          data.Last_Name__c,\n\n        project:\n          data.Project_Text__c\n      }\n    };\n\n  })\n\n  .filter(Boolean);"
        },
