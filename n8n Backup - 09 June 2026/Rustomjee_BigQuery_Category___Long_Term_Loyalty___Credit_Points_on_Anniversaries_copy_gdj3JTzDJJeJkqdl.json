          "jsCode": "const today = new Date();\n\nconst todayMonth =\n  today.getMonth();\n\nconst todayDate =\n  today.getDate();\n\nreturn items\n\n  .map(item => {\n\n    const bookingDate =\n      new Date(item.json.booking_date);\n\n    // Invalid date\n    if (\n      isNaN(bookingDate.getTime())\n    ) {\n      return null;\n    }\n\n    const bookingMonth =\n      bookingDate.getMonth();\n\n    const bookingDay =\n      bookingDate.getDate();\n\n    const yearsCompleted =\n      today.getFullYear() -\n      bookingDate.getFullYear();\n\n    let points = 0;\n\n    if (yearsCompleted === 1) {\n      points = 200;\n    }\n    else if (yearsCompleted === 5) {\n      points = 500;\n    }\n    else if (yearsCompleted === 10) {\n      points = 1000;\n    }\n    else if (yearsCompleted === 15) {\n      points = 1500;\n    }\n\n    const isAnniversary =\n      todayMonth === bookingMonth &&\n      todayDate === bookingDay;\n\n    return {\n      json: {\n\n        ...item.json,\n\n        years_completed:\n          yearsCompleted,\n\n        points:\n          points,\n\n        is_anniversary:\n          isAnniversary\n      }\n    };\n\n  })\n\n  .filter(Boolean);"
        },
