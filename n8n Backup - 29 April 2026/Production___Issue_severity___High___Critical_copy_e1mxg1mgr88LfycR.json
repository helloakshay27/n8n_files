            "query": "SELECT\n  i.*,\n  i.id            AS issue_id,\n  i.title         AS issue_title,\n  i.priority      AS issue_priority,\n  i.created_at    AS issue_created_at,\n\n  pm.id           AS project_id,\n  pm.title        AS project_title,\n\n  pm_owner.email      AS project_manager_email,\n  pm_owner.firstname  AS project_manager_firstname,\n  pm_owner.lastname   AS project_manager_lastname,\n\n  tl.id               AS team_lead_id,\n  tl.email            AS team_lead_email,\n  tl.firstname        AS team_lead_firstname,\n  tl.lastname         AS team_lead_lastname,\n\n  rp.id               AS responsible_person_id,\n  rp.firstname        AS responsible_person_firstname,\n  rp.lastname         AS responsible_person_lastname,\n  rp.email            AS responsible_person_email,\n\n  m.title             AS milestone_title,\n  tm.title            AS task_title\n\nFROM issues i\n\nJOIN project_managements pm\n  ON pm.id = i.project_management_id\n\nJOIN spree_users pm_owner\n  ON pm_owner.id = pm.owner_id\n\nLEFT JOIN project_teams pt\n  ON pt.id = pm.project_team_id\n\nLEFT JOIN spree_users tl\n  ON tl.id = pt.team_lead_id\n\nLEFT JOIN spree_users rp\n  ON rp.id = i.responsible_person_id\n\nLEFT JOIN milestones m\n  ON m.id = i.milestone_id\n\nLEFT JOIN task_managements tm\n  ON tm.id = i.task_management_id\n\nWHERE\n  i.created_at >= UTC_TIMESTAMP() - INTERVAL 10 MINUTE\n  AND LOWER(i.priority) IN ('high', 'urgent')\n  AND rp.organization_id IN (13, 14, 59, 84);",
            "options": {}
          },
          "type": "n8n-nodes-base.mySql",
          "typeVersion": 2.5,
          "position": [
            -272,
            -224
          ],
          "id": "5a3c28ab-0d05-4c37-b125-5e7a171b9867",
