      {
        "parameters": {
          "jsCode": "const map = {};\n\nfor (const item of $input.all()) {\n  const data = item.json;\n  const userId = data.user_id;\n\n  if (!map[userId]) {\n    map[userId] = {\n      user_id: userId,\n      total_todos_today: 0,\n      completed_todos_today: 0\n    };\n  }\n\n  if (typeof data.total_todos_today === 'number') {\n    map[userId].total_todos_today = data.total_todos_today;\n  }\n\n  if (typeof data.completed_todos_today === 'number') {\n    map[userId].completed_todos_today = data.completed_todos_today;\n  }\n}\n\nreturn Object.values(map).map(v => ({ json: v }));\n"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          -336,
          64
        ],
        "id": "cab3d523-5c89-464c-b76d-ef0914ff7439",
        "name": "Get Streamline Output",
        "alwaysOutputData": true
      },
      {
        "parameters": {
          "jsCode": "const DAILY_TODO_POOL = 20.83; // 10% of daily pool (≈ 208.33 * 10%)\n\nconst output = [];\n\nfor (const item of $input.all()) {\n  const user_id = item.json.user_id;\n  const total = Number(item.json.total_todos_today || 0);\n  const completed = Number(item.json.completed_todos_today || 0);\n\n  if (total === 0) continue;\n\n  const ratio = completed / total;\n  let points = ratio * DAILY_TODO_POOL;\n\n  // safety cap\n  if (points > DAILY_TODO_POOL) {\n    points = DAILY_TODO_POOL;\n  }\n\n  points = Number(points.toFixed(2));\n\n  if (points <= 0) continue;\n\n  output.push({\n    json: {\n      user_id,\n      points,\n      remark: `Daily todo completion: ${completed}/${total}`\n    }\n  });\n}\n\nreturn output;\n"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          -176,
          192
        ],
        "id": "1183f02a-850d-4521-a2bc-9e19abf9e01a",
        "name": "Calculation Of Total Points",
        "alwaysOutputData": true
      },
      {
        "parameters": {
          "jsCode": "const DAILY_CAP = 208.33;\nconst TASK_PERCENT = 0.20;\nconst DAILY_TASK_MAX = DAILY_CAP * TASK_PERCENT; // 41.66\n\nconst items = $input.all();\n\nconst assignedMap = {};\nconst completedMap = {};\n\nfor (const item of items) {\n  const data = item.json;\n\n  if (data.total_tasks_today !== undefined) {\n    assignedMap[data.user_id] = Number(data.total_tasks_today);\n  }\n\n  if (data.completed_tasks_today !== undefined) {\n    completedMap[data.user_id] = Number(data.completed_tasks_today);\n  }\n}\n\nconst output = [];\n\nfor (const userId in assignedMap) {\n  const total = assignedMap[userId];\n  const done = completedMap[userId] || 0;\n\n  if (!total || total <= 0 || done <= 0) continue;\n\n  const ratio = done / total;\n  const points = Math.min(\n    DAILY_TASK_MAX,\n    Number((ratio * DAILY_TASK_MAX).toFixed(2))\n  );\n\n  if (points <= 0) continue;\n\n  output.push({\n    json: {\n      user_id: Number(userId),\n      points,\n      remark: `Daily task completion: ${done}/${total}`\n    }\n  });\n}\n\nreturn output;\n"
        },
