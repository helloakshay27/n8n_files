      {
        "parameters": {
          "jsCode": "return items.map(item => {\n\nreturn {\njson: {\nid: item.json.id,\ncustomer_id: item.json.customer_id,\nmobile: item.json.mobile,\npoints_to_credit: item.json.points,\nevent: \"BOOKING_ANNIVERSARY\",\nyears_completed: item.json.years_completed,\nbooking_date: item.json.booking_date,\ntoday_delta_additions: item.json.today_delta_additions\n}\n};\n\n});"
