      {
        "parameters": {
          "fromEmail": "notificaions@lockated.com",
          "toEmail": "={{ $json.todo_owner_email }}",
          "subject": "= New To-Do Assigned – {{$json.todo_title}}\n",
          "emailFormat": "=html",
          "html": "=<div style=\"font-family: Arial, sans-serif; font-size: 14px; color: #333;\">\n\n  <p>Dear {{$json.todo_owner_firstname}} {{$json.todo_owner_lastname}},</p>\n\n  <p>A new to-do item has been assigned to you.</p>\n\n  <h3 style=\"color: #2980b9;\">To-Do Details</h3>\n\n  <table style=\"border-collapse: collapse; width: 100%; max-width: 600px;\">\n\n    <tr>\n      <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>To-Do Title</strong></td>\n      <td style=\"padding: 8px; border: 1px solid #ddd;\">{{$json.todo_title}}</td>\n    </tr>\n\n    <tr>\n      <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>Status</strong></td>\n      <td style=\"padding: 8px; border: 1px solid #ddd;\">{{$json.todo_status}}</td>\n    </tr>\n\n    <tr>\n      <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>Priority</strong></td>\n      <td style=\"padding: 8px; border: 1px solid #ddd;\">{{$json.priority}}</td>\n    </tr>\n\n    <tr>\n      <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>Created On</strong></td>\n      <td style=\"padding: 8px; border: 1px solid #ddd;\">{{$json.created_at}}</td>\n    </tr>\n\n    <tr>\n      <td style=\"padding: 8px; border: 1px solid #ddd;\"><strong>End On / Target Date</strong></td>\n      <td style=\"padding: 8px; border: 1px solid #ddd;\">{{$json.target_date}}</td>\n    </tr>\n\n  </table>\n\n  <p>Please ensure timely completion.</p>\n\n  <p>Regards,<br>\n  <b>Task System</b></p>\n\n</div>",
          "options": {}
        },
        "type": "n8n-nodes-base.emailSend",
        "typeVersion": 2.1,
        "position": [
          48,
          -160
        ],
        "id": "e514e490-2944-48e0-96cb-72a76618031c",
        "name": "User",
        "webhookId": "e76eb7db-e8bf-4f1f-a774-3b61ef773fa5",
        "alwaysOutputData": true,
        "credentials": {
          "smtp": {
            "id": "e6BxRubia0RizPKp",
            "name": "Lockated Local SMTP"
          }
        }
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT\n  t.*,\n  t.id            AS todo_id,\n  t.title         AS todo_title,\n  t.status        AS todo_status,\n  t.target_date,\n  t.created_at,\n\n  u.email         AS todo_owner_email,\n  u.firstname     AS todo_owner_firstname,\n  u.lastname      AS todo_owner_lastname\n\nFROM todos t\n\nJOIN spree_users u\n  ON u.id = t.user_id\n\nWHERE\n  t.created_at >= UTC_TIMESTAMP() - INTERVAL 10 MINUTE\n  AND u.organization_id IN (13, 14, 59, 84);",
          "options": {}
        },
        "type": "n8n-nodes-base.mySql",
        "typeVersion": 2.5,
        "position": [
          -192,
          -224
        ],
        "id": "b88faac0-d679-48de-8818-8ba7cd0e8198",
        "name": "Execute a SQL query",
