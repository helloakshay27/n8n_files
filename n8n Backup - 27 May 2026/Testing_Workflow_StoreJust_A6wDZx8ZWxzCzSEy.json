      {
        "parameters": {
          "jsCode": "return items.map(item => {\n    \n    const user = item.json;\n\n    return {\n        json: {\n            customer_code: user.customer_code,\n            Id: null,\n            booking_id: null,\n            customer_name: `${user.firstname || ''} ${user.lastname || ''}`.trim(),\n            email: user.email,\n            amount: 1000,\n            remarks: \"BIRTHDAY BONUS POINTS\",\n            transaction_note: \"Points credited automatically for birthday reward\",\n            payment_mode: \"system\",\n            topup_by: \"automation\",\n            transaction_date: new Date().toISOString(),\n            today_delta_additions: null\n        }\n    };\n});"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
