    {
      "parameters": {
        "fromEmail": "notifications@lockated.com",
        "toEmail": "={{$json.task_owner_email}}\n",
        "subject": "=Task Due Reminder (24 Hours): {{$json.task_title}}\n\n",
        "html": "=<p>Dear {{$json.task_owner_firstname}} {{$json.task_owner_lastname}},</p>\n\n<p>This is a reminder that the task <b>{{$json.task_title}}</b> is due within the next <b>24 hours</b>.</p>\n\n<p>Task Schedule:<br>\n* Task Title: {{$json.task_title}}<br>\n* Due Date: {{$json.task_due_date}}<br>\n* Current Status: {{$json.task_status}}</p>\n\n<p>Please prioritize completion or update the task with revised timelines if required.</p>\n\n<p>Regards,<br>\nTask Management System</p>",
        "options": {}
      },
      "type": "n8n-nodes-base.emailSend",
      "typeVersion": 2.1,
      "position": [
        32,
        -176
      ],
      "id": "15bdf341-208e-4038-a312-7a023ca014f4",
      "name": "Task Owner",
      "webhookId": "0c75e6ff-b2aa-4284-bf07-af8b1d2d9be7",
      "alwaysOutputData": true,
      "credentials": {
        "smtp": {
          "id": "e6BxRubia0RizPKp",
          "name": "Lockated Local SMTP"
        }
      }
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  t.id                    AS task_id,\n  t.title                 AS task_title,\n  t.target_date           AS task_due_date,\n  t.status                AS task_status,\n  t.parent_id             AS parent_id,\n\n  -- hours remaining\n  TIMESTAMPDIFF(\n    HOUR,\n    UTC_TIMESTAMP(),\n    t.target_date\n  )                       AS hours_remaining,\n\n  -- task owner\n  rp.email                AS task_owner_email,\n  rp.firstname            AS task_owner_firstname,\n  rp.lastname             AS task_owner_lastname,\n\n  -- project info (optional but useful in email)\n  pm.id                   AS project_id,\n  pm.title                AS project_title\n\nFROM task_managements t\n\n-- task owner\nJOIN spree_users rp\n  ON rp.id = t.responsible_person_id\n\n-- project\nJOIN project_managements pm\n  ON pm.id = t.project_management_id\n\nWHERE\n  t.status NOT IN ('completed', 'closed')\n  AND t.target_date > UTC_TIMESTAMP()                     -- not overdue\n  AND t.target_date <= UTC_TIMESTAMP() + INTERVAL 40 HOUR\n  AND t.parent_id IS NULL;",
        "options": {}
      },
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.5,
      "position": [
        -192,
        -272
      ],
      "id": "fb2e05ed-628b-4f07-9a3a-a06e13f48acc",
