    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  t.id                    AS task_id,\n  t.title                 AS task_title,\n  t.target_date           AS task_due_date,\n  t.status                AS task_status,\n\n  TIMESTAMPDIFF(\n    HOUR,\n    UTC_TIMESTAMP(),\n    t.target_date\n  )                       AS hours_remaining,\n\n  rp.email                AS task_owner_email,\n  rp.firstname            AS task_owner_firstname,\n  rp.lastname             AS task_owner_lastname,\n\n  pm.id                   AS project_id,\n  pm.title                AS project_title\n\nFROM task_managements t\n\nJOIN spree_users rp\n  ON rp.id = t.responsible_person_id\n\n-- parent task\nLEFT JOIN task_managements parent_t\n  ON parent_t.id = t.parent_id\n\n-- project from self OR parent\nLEFT JOIN project_managements pm\n  ON pm.id = COALESCE(\n    t.project_management_id,\n    parent_t.project_management_id\n  )\n\nWHERE\n  t.status NOT IN ('completed', 'closed')\n  AND t.target_date > UTC_TIMESTAMP()\n  AND t.target_date <= UTC_TIMESTAMP() + INTERVAL 40 HOUR\n  AND t.parent_id IS NOT NULL;  -- ✅ only subtasks",
        "options": {}
      },
