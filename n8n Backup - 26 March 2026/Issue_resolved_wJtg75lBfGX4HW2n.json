    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT\n  i.*,\n  i.id                AS issue_id,\n  i.title             AS issue_title,\n  i.status            AS issue_status,\n  i.updated_at        AS issue_updated_at,\n\n  pm.id               AS project_id,\n  pm.title            AS project_title,\n\n  -- project manager\n  pmo.email           AS project_manager_email,\n  pmo.firstname       AS project_manager_firstname,\n  pmo.lastname        AS project_manager_lastname,\n\n  -- issue reporter (created by)\n  reporter.email      AS reporter_email,\n  reporter.firstname  AS reporter_firstname,\n  reporter.lastname   AS reporter_lastname\n\nFROM issues i\n\n-- project\nJOIN project_managements pm\n  ON pm.id = i.project_management_id\n\n-- project manager\nJOIN spree_users pmo\n  ON pmo.id = pm.owner_id\n\n-- issue reporter\nJOIN spree_users reporter\n  ON reporter.id = i.created_by_id\n\nWHERE\n  i.status IN ('completed', 'closed')\n  AND i.updated_at >= UTC_TIMESTAMP() - INTERVAL 60 MINUTE\n  AND i.updated_at > i.created_at;\n",
        "options": {}
      },
      "type": "n8n-nodes-base.mySql",
      "typeVersion": 2.5,
      "position": [
        -192,
        -256
      ],
