    {
      "parameters": {
        "jsCode": "// Collect all items and parse Gemini responses\nconst items = $input.first().json.steps;\n\nconst steps = items.map((item, i) => {\n  let annotation = {};\n  try {\n    const raw = item.json.candidates?.[0]?.content?.parts?.[0]?.text || '{}';\n    const clean = raw.replace(/```json|```/g, '').trim();\n    annotation = JSON.parse(clean);\n  } catch(e) {\n    annotation = {\n      stepTitle: `Step ${i + 1}`,\n      tooltip: 'Follow the instructions on screen.',\n      highlightElement: '',\n      elementDescription: ''\n    };\n  }\n  return {\n    step: i + 1,\n    annotation\n  };\n});\n\n// ── BUILD THE HTML DEMO ──────────────────────────────────────────────────────\nconst totalSteps = steps.length;\n\nconst stepCards = steps.map((s, i) => `\n  {\n    step: ${s.step},\n    title: ${JSON.stringify(s.annotation.stepTitle || `Step ${s.step}`)},\n    tooltip: ${JSON.stringify(s.annotation.tooltip || '')},\n    highlight: ${JSON.stringify(s.annotation.highlightElement || '')},\n    elementDesc: ${JSON.stringify(s.annotation.elementDescription || '')}\n  }`).join(',');\n\nconst html = `<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>How to Login — Lockated</title>\n<style>\n  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap');\n  *{box-sizing:border-box;margin:0;padding:0}\n  body{font-family:'DM Sans',system-ui,sans-serif;background:#0e0f11;color:#e8eaf0;min-height:100vh;display:flex;flex-direction:column}\n  .hdr{display:flex;align-items:center;justify-content:space-between;padding:14px 28px;background:#16181c;border-bottom:1px solid #2a2d35}\n  .hdr-left{display:flex;align-items:center;gap:10px}\n  .dot{width:8px;height:8px;border-radius:50%;background:#4f8ef7}\n  .hdr-title{font-size:14px;font-weight:500}\n  .badge{font-size:11px;color:#6b7280;background:#1e2026;border:1px solid #2a2d35;border-radius:20px;padding:3px 12px}\n  .pills{display:flex;gap:6px}\n  .pill{height:5px;min-width:28px;border-radius:3px;background:#2a2d35;cursor:pointer;transition:all .2s}\n  .pill.active{background:#4f8ef7;min-width:36px}\n  .pill.done{background:#34d399}\n  .nav{display:flex;align-items:center;gap:10px}\n  .count{font-size:12px;color:#6b7280;min-width:44px;text-align:center}\n  .btn{padding:8px 20px;border-radius:8px;border:1px solid #2a2d35;background:transparent;color:#e8eaf0;font-family:inherit;font-size:13px;cursor:pointer;transition:all .15s}\n  .btn:hover{background:#1e2026}\n  .btn.p{background:#4f8ef7;border-color:#4f8ef7;color:#fff}\n  .btn.p:hover{background:#3a7bf0}\n  .progress{height:3px;background:#2a2d35}\n  .pbar{height:100%;background:#4f8ef7;transition:width .4s ease}\n  .stage{flex:1;display:flex;align-items:stretch;gap:0;min-height:500px}\n  .dom-panel{flex:1;padding:32px;overflow-y:auto;background:#09090b;border-right:1px solid #2a2d35}\n  .dom-panel pre{font-family:'DM Mono',monospace;font-size:12px;color:#9ca3af;line-height:1.7;white-space:pre-wrap;word-break:break-word}\n  .info-panel{width:320px;padding:28px;display:flex;flex-direction:column;gap:20px;background:#16181c;flex-shrink:0}\n  .step-num{font-size:11px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#4f8ef7}\n  .step-title{font-size:20px;font-weight:600;line-height:1.3;margin-top:6px}\n  .tooltip-box{background:#1a1f2e;border:1px solid #4f8ef7;border-radius:10px;padding:16px}\n  .tooltip-label{font-size:10px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#4f8ef7;margin-bottom:8px}\n  .tooltip-text{font-size:13px;color:#e8eaf0;line-height:1.6}\n  .highlight-box{background:#1e2026;border:1px solid #2a2d35;border-radius:8px;padding:14px;margin-top:4px}\n  .highlight-label{font-size:10px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:#6b7280;margin-bottom:6px}\n  .highlight-id{font-family:'DM Mono',monospace;font-size:12px;color:#fbbf24;background:#2a2200;border:1px solid #3a3000;border-radius:4px;padding:2px 8px;display:inline-block;margin-bottom:6px}\n  .highlight-desc{font-size:12px;color:#9ca3af;line-height:1.5}\n  .bottom{padding:16px 28px;background:#16181c;border-top:1px solid #2a2d35;font-size:12px;color:#6b7280;text-align:center}\n</style>\n</head>\n<body>\n\n<div class=\"hdr\">\n  <div class=\"hdr-left\">\n    <div class=\"dot\"></div>\n    <div class=\"hdr-title\">Lockated</div>\n    <div class=\"badge\">How to Login</div>\n  </div>\n  <div class=\"pills\" id=\"pills\"></div>\n  <div class=\"nav\">\n    <span class=\"count\" id=\"count\"></span>\n    <button class=\"btn\" onclick=\"prev()\">← Back</button>\n    <button class=\"btn p\" id=\"btnnext\" onclick=\"next()\">Next →</button>\n  </div>\n</div>\n\n<div class=\"progress\"><div class=\"pbar\" id=\"pbar\"></div></div>\n\n<div class=\"stage\">\n  <div class=\"dom-panel\">\n    <pre id=\"dom-view\"></pre>\n  </div>\n  <div class=\"info-panel\">\n    <div>\n      <div class=\"step-num\" id=\"step-num\"></div>\n      <div class=\"step-title\" id=\"step-title\"></div>\n    </div>\n    <div class=\"tooltip-box\">\n      <div class=\"tooltip-label\">What to do</div>\n      <div class=\"tooltip-text\" id=\"tooltip-text\"></div>\n    </div>\n    <div class=\"highlight-box\">\n      <div class=\"highlight-label\">Key element</div>\n      <div class=\"highlight-id\" id=\"highlight-id\"></div>\n      <div class=\"highlight-desc\" id=\"highlight-desc\"></div>\n    </div>\n  </div>\n</div>\n\n<div class=\"bottom\">Use ← → arrow keys or buttons to navigate &nbsp;·&nbsp; ${totalSteps} steps total</div>\n\n<script>\nconst steps = [${stepCards}];\nlet cur = 0;\n\nfunction render(i) {\n  const s = steps[i];\n  document.getElementById('pbar').style.width = ((i+1)/steps.length*100)+'%';\n  document.getElementById('count').textContent = (i+1)+' / '+steps.length;\n  document.getElementById('btnnext').textContent = i===steps.length-1 ? 'Finish ✓' : 'Next →';\n  document.getElementById('step-num').textContent = 'Step '+(i+1)+' of '+steps.length;\n  document.getElementById('step-title').textContent = s.title;\n  document.getElementById('tooltip-text').textContent = s.tooltip;\n  document.getElementById('highlight-id').textContent = s.highlight || '—';\n  document.getElementById('highlight-desc').textContent = s.elementDesc || '';\n  document.getElementById('dom-view').textContent = 'Loading DOM for step '+(i+1)+'...';\n  const pills = document.getElementById('pills');\n  pills.innerHTML = '';\n  steps.forEach((_,idx) => {\n    const p = document.createElement('div');\n    p.className = 'pill'+(idx===i?' active':idx<i?' done':'');\n    p.title = steps[idx].title;\n    p.onclick = () => { cur=idx; render(idx); };\n    pills.appendChild(p);\n  });\n}\n\nfunction prev(){if(cur>0){cur--;render(cur);}}\nfunction next(){if(cur<steps.length-1){cur++;render(cur);}else{document.getElementById('btnnext').textContent='✓ Done';}}\ndocument.addEventListener('keydown',e=>{if(e.key==='ArrowRight'||e.key===' ')next();if(e.key==='ArrowLeft')prev();});\nrender(0);\n<\\/script>\n</body>\n</html>`;\n\nconst binaryData = Buffer.from(html, 'utf8').toString('base64');\n\nreturn [{\n  json: { filename: 'how-to-login.html' },\n  binary: {\n    data: {\n      data: binaryData,\n      mimeType: 'text/html',\n      fileName: 'how-to-login.html',\n      fileExtension: 'html'\n    }\n  }\n}];"
      },
