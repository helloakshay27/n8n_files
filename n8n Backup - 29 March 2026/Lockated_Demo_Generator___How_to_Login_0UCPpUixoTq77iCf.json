      "parameters": {
        "jsCode": "const step = $input.first().json;\n\nconst prompt = `You are building an interactive product demo for Lockated.\n\nStep ${step.step} of 6: ${step.title}\n\nHTML Element Tree:\n${step.html}\n\nReturn ONLY valid JSON, no markdown:\n{\"stepTitle\": \"<4-5 word action>\", \"tooltip\": \"<one clear instruction sentence>\", \"highlightElement\": \"<id of key element e.g. AAAP>\", \"elementDescription\": \"<plain English description>\"}`;\n\nreturn [{\n  json: {\n    step: step.step,\n    title: step.title,\n    html: step.html,\n    requestBody: JSON.stringify({\n      contents: [{ parts: [{ text: prompt }] }],\n      generationConfig: { maxOutputTokens: 300, temperature: 0.1 }\n    })\n  }\n}];"
