        "jsCode": "const userGuideText = items[0].json.data;\nconst geminiText = items[1].json.data;\n\nconst prompt = \"You are a product guide automation engine. Read the two documents below and extract every step a user performs. Return ONLY valid JSON with this structure: {\\\"title\\\": \\\"guide title\\\", \\\"steps\\\": [{\\\"step_number\\\": 1, \\\"title\\\": \\\"step title\\\", \\\"action\\\": \\\"what user does\\\", \\\"where\\\": \\\"UI location\\\", \\\"narration\\\": \\\"voiceover max 15 words\\\", \\\"expected_result\\\": \\\"what appears on screen\\\"}]}\\n\\nDOCUMENT 1:\\n\" + userGuideText + \"\\n\\nDOCUMENT 2:\\n\" + geminiText;\n\nconst body = {\n  contents: [{\n    parts: [{\n      text: prompt\n    }]\n  }],\n  generationConfig: {\n    temperature: 0.2\n  }\n};\n\nreturn [{\n  json: {\n    requestBody: JSON.stringify(body)\n  }\n}];"
