      ],
      "typeVersion": 1
    },
    {
      "parameters": {
        "content": "## ✅ Final Output Format\n\nSuccess:\n{\n  \"videoId\": \"xObjAdhDxBE\",\n  \"language\": \"es\",\n  \"text\": \"Clean transcript text...\",\n  \"wordCount\": 1234,\n  \"charCount\": 5678,\n  \"status\": \"success\",\n  \"source\": \"youtube_transcript_api\"\n}",
        "height": 380,
