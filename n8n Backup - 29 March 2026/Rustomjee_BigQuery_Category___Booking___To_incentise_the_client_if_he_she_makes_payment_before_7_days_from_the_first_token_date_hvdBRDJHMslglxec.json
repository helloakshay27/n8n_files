    {
      "parameters": {
        "jsCode": "return items\n  .map(item => {\n\n    const data = item.json;\n\n    const mobile =\n      data.Account_Mobile_Number__c ||\n      data.Account_Mobile_1__c ||\n      data.Mobile_Number__c ||\n      null;\n\n    const customer_id = data.KUNNR || null;\n\n    return {\n      json: {\n        mobile: mobile,\n        customer_id: customer_id,\n        agreement_value: Number(data.Agreement_Value__c) || 0,\n        booking_date: data.Booking_Date,\n        token_date: data.X9_9_Received_Date__c\n      }\n    };\n  })\n\n  // 🚨 remove invalid rows\n  .filter(item => item.json.mobile !== null);"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        32,
        -32
      ],
      "id": "88e25dea-fe5c-4e60-9e1f-d17c665150b1",
