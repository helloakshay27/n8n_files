      "alwaysOutputData": true
    },
    {
      "parameters": {
        "authentication": "serviceAccount",
        "projectId": {
          "__rl": true,
          "value": "powerbi-implementation",
          "mode": "list",
          "cachedResultName": "PowerBI Implementation",
          "cachedResultUrl": "https://console.cloud.google.com/bigquery?project=powerbi-implementation"
        },
        "sqlQuery": "SELECT\n  Booking_Date,\n  X9_9_Received_Date__c,\n  KUNNR,\n  Account_Mobile_Number__c,\n  Account_Mobile_1__c,\n  Mobile_Number__c,\n  Agreement_Value__c\nFROM powerbi-implementation.dataWarehouse_prod.sales_booking\nWHERE \n  Status__c = 'Processed'\n\n  -- Ensure values exist\n  AND X9_9_Received_Date__c IS NOT NULL\n  AND Booking_Date IS NOT NULL\n\n  -- Convert STRING → DATE\n  AND DATE(Booking_Date) BETWEEN \n      PARSE_DATE('%Y-%m-%d', X9_9_Received_Date__c)\n      AND DATE_ADD(\n            PARSE_DATE('%Y-%m-%d', X9_9_Received_Date__c),\n            INTERVAL 7 DAY\n      )",
        "options": {}
      },
      "type": "n8n-nodes-base.googleBigQuery",
      "typeVersion": 2.1,
      "position": [
        -144,
        -128
      ],
      "id": "35152b78-8a7a-4553-b11f-0a20f6133359",
