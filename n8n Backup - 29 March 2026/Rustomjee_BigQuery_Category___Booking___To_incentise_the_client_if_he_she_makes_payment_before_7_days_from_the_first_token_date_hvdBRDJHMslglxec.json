        }
      }
    },
    {
      "parameters": {
        "jsCode": "return items.map(item => {\n\n  return {\n    json: {\n      customer_mobile: item.json.mobile,\n      customer_id: item.json.customer_id,\n\n      points: 1000, // fixed reward (can make dynamic later)\n\n      event: \"booking_within_7_days\",\n      reason: \"Payment done within 7 days of token date\",\n\n      booking_date: item.json.booking_date,\n      token_date: item.json.token_date,\n\n      created_at: new Date().toISOString()\n    }\n  };\n\n});"
      },
