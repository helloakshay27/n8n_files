        "jsCode": "return items.map(item => {\n  return {\n    json: {\n      customer_mobile: item.json.mobile,\n      customer_name: `${item.json.FirstName} ${item.json.LastName}`,\n      points: 1000,\n      reason: \"Birthday Reward\",\n      email: item.json.email,\n      birthday: item.json.Birth_Date__c\n    }\n  };\n});"
