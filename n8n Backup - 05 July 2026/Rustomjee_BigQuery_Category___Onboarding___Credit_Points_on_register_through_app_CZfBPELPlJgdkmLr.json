          "query": "USE storejust;\n\nSELECT DISTINCT\n    su.customer_code,\n    su.mobile,\n    su.email,\n    su.id AS user_id\nFROM spree_users su\nINNER JOIN user_devices ud\n    ON su.id = ud.user_id\nWHERE customer_code = '476035' AND\n    su.organization_id = 9\n    AND su.customer_code IS NOT NULL\n    AND su.customer_code <> ''\n    AND ud.device_id IN (1,2);\n\n/* USE storejust;\n\nSELECT\n    su.customer_code,\n    su.mobile,\n    su.email,\n    su.id AS user_id,\n    ud.device_type,\n    ud.device_id\nFROM spree_users su\nINNER JOIN user_devices ud\n    ON su.id = ud.user_id\nWHERE\n    su.organization_id = 9\n    AND su.customer_code IS NOT NULL\n    AND su.customer_code <> ''\n    AND ud.device_id IN (1,2);\n*/",
