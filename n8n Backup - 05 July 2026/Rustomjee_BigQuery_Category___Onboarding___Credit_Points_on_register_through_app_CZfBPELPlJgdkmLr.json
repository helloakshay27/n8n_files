          "jsCode": "const today = new Date().toISOString().split('T')[0];\n\nreturn items.map(item => {\n\n  const customerCode = item.json.customer_code;\n  const mobile = item.json.mobile || '';\n  const email = item.json.email || '';\n\n  return {\n    json: {\n      customer_code: customerCode,\n      customer_mobile: mobile,\n      email: email,\n      customer_unique_key: `${mobile}_${email}`,\n      opportunity_id: customerCode,\n      today_date: today,\n      amount: 100,\n      remarks: \"App Download Reward\",\n      transaction_note: \"Credit point for taking survey\",\n      payment_mode: \"cash\",\n      topup_by: \"automation\",\n      today_delta_additions: today\n    }\n  };\n});"
