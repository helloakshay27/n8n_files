      {
        "parameters": {
          "authentication": "serviceAccount",
          "projectId": {
            "__rl": true,
            "value": "powerbi-implementation",
            "mode": "list",
            "cachedResultName": "PowerBI Implementation",
            "cachedResultUrl": "https://console.cloud.google.com/bigquery?project=powerbi-implementation"
          },
          "sqlQuery": "SELECT \n  Customer_No__c,\n  ID,\n  Account_Email__c,\n\n  -- Single unified mobile field\n  REGEXP_REPLACE(\n    COALESCE(\n      Account_Mobile_1__c,\n      Account_Mobile_2__c,\n      Account_Mobile_Number__c\n    ),\n    r'[^0-9]',\n    ''\n  ) AS customer_mobile,\n\nFROM `powerbi-implementation.dataWarehouse_prod.opportunity_survey`\n\nWHERE \n  Survey_Name__c IN (\n    'FirstSiteVisitDoneLapsSurvey',\n    'FirstSiteVisitDoneSurvey',\n    'RevisitDoneDeleySurvey',\n    'RevisitDoneSurvey'\n  )\n  AND Status__c = 'Completed'\n  AND LOWER(REPLACE(TRIM(StageName), ' ', '')) IN (\n    'sitevisitdone',\n    'revisitdone',\n    'bookingconfirmed'\n  )\n  AND Booking__c IS NOT NULL\n\nQUALIFY ROW_NUMBER() OVER (\n  PARTITION BY Customer_No__c\n  ORDER BY ID\n) = 1;\n\n/* SELECT \n  Customer_No__c,\n  ID,\n  Account_Email__c,\n\n  -- Single unified mobile field\n  REGEXP_REPLACE(\n    COALESCE(\n      Account_Mobile_1__c,\n      Account_Mobile_2__c,\n      Account_Mobile_Number__c\n    ),\n    r'[^0-9]',\n    ''\n  ) AS customer_mobile,\n\n  today_delta_additions\n\nFROM `powerbi-implementation.dataWarehouse_prod.opportunity_survey`\n\nWHERE \n  Survey_Name__c IN (\n    'FirstSiteVisitDoneLapsSurvey',\n    'FirstSiteVisitDoneSurvey',\n    'RevisitDoneDeleySurvey',\n    'RevisitDoneSurvey'\n  )\n\n  AND Status__c = 'Completed'\n\n  -- Robust StageName matching\n  AND LOWER(REPLACE(TRIM(StageName), ' ', '')) IN (\n    'sitevisitdone',\n    'revisitdone',\n    'bookingconfirmed'\n\n  )\n  AND Booking__c IS NOT NULL LIMIT 50;\n\n  -- -- Ensure at least one mobile exists\n  -- AND (\n  --   Account_Mobile_1__c IS NOT NULL OR\n  --   Account_Mobile_2__c IS NOT NULL OR\n  --   Account_Mobile_Number__c IS NOT NULL\n  -- )\n\n  -- -- Ensure email exists\n  -- AND Account_Email__c IS NOT NULL;\n*/",
          "options": {}
        },
        "type": "n8n-nodes-base.googleBigQuery",
        "typeVersion": 2.1,
