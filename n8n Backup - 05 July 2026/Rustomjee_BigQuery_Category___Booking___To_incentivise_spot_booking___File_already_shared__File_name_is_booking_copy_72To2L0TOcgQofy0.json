          "jsCode": "return $input.all().map(item => {\n\n  return {\n    json: {\n\n      id: item.json.id,\n\n      customer_mobile:\n        item.json.mobile,\n\n      customer_code:\n        item.json.customer_id,\n\n      amount:\n        item.json.reward_points,\n\n      remarks:\n        item.json.reward_type,\n\n      transaction_note:\n        \"Booking incentive based on SV timing\",\n\n      payment_mode: \"cash\",\n\n      topup_by: \"automation\",\n\n      booking_id:\n        item.json.booking_id,\n\n      project:\n        item.json.project,\n\n      days_difference:\n        item.json.days_difference,\n\n      reward_percentage:\n        item.json.reward_percentage,\n\n      created_at:\n        new Date().toISOString(),\n\n      today_delta_additions:\n        item.json.today_delta_additions\n    }\n  };\n\n});"
