      {
        "parameters": {
          "jsCode": "const output = [];\n\n// Safe date parser\nconst parseDate = (dateValue) => {\n\n  if (!dateValue) return null;\n\n  const d = new Date(dateValue);\n\n  return isNaN(d.getTime()) ? null : d;\n};\n\nfor (const item of $input.all()) {\n\n  const row = item.json;\n\n  // Pick first available mobile\n  const mobile =\n    row.Account_Mobile_Number__c ||\n    row.Account_Mobile_1__c ||\n    row.Mobile_Number__c ||\n    null;\n\n  // Skip if no mobile\n  if (!mobile) continue;\n\n  // Parse dates safely\n  const svDate = parseDate(row.SV_Date__c);\n\n  let bookingDate = null;\n\n  if (row.Booking_Date) {\n    bookingDate = parseDate(row.Booking_Date);\n  }\n  else if (row.SM_Next_Action_Date__c) {\n    bookingDate = parseDate(row.SM_Next_Action_Date__c);\n  }\n\n  // Skip invalid dates\n  if (!svDate || !bookingDate) continue;\n\n  // Required validations\n  if (\n    !row.Registration_Date__c ||\n    !row.Registration_Number__c\n  ) {\n    continue;\n  }\n\n  output.push({\n    json: {\n\n      id: row.ID,\n\n      mobile: mobile,\n\n      customer_id: row.KUNNR || null,\n\n      sv_date: svDate,\n\n      booking_date: bookingDate,\n\n      booking_id: row.X18_Digit_Booking_ID__c,\n\n      project: row.Project_Name,\n\n      status: row.Status__c,\n\n      today_delta_additions:\n        row.today_delta_additions\n    }\n  });\n\n}\n\nreturn output;"
        },
