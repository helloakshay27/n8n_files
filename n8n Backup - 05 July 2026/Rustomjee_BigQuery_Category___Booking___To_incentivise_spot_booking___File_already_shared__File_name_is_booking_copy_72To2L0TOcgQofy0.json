      {
        "parameters": {
          "jsCode": "const output = [];\n\n// Maximum reward points\nconst MAX_REWARD = 1000;\n\nfor (const item of $input.all()) {\n\n  const sv = new Date(item.json.sv_date);\n\n  const booking =\n    new Date(item.json.booking_date);\n\n  // Difference in days\n  const diffDays = Math.floor(\n    (booking - sv) /\n    (1000 * 60 * 60 * 24)\n  );\n\n  let percentage = 0;\n\n  let reward_type = \"\";\n\n  // Same day booking\n  if (diffDays === 0) {\n\n    percentage = 1.0;\n\n    reward_type =\n      \"Spot Offer (100%)\";\n  }\n\n  // Within 7 days\n  else if (\n    diffDays > 0 &&\n    diffDays <= 7\n  ) {\n\n    percentage = 0.75;\n\n    reward_type =\n      \"Within 7 Days (75%)\";\n  }\n\n  // Within 15 days\n  else if (\n    diffDays > 7 &&\n    diffDays <= 15\n  ) {\n\n    percentage = 0.50;\n\n    reward_type =\n      \"Within 15 Days (50%)\";\n  }\n\n  // Ignore beyond 15 days\n  if (percentage <= 0) {\n    continue;\n  }\n\n  const reward =\n    Math.round(MAX_REWARD * percentage);\n\n  output.push({\n    json: {\n\n      ...item.json,\n\n      days_difference: diffDays,\n\n      reward_points: reward,\n\n      reward_percentage:\n        percentage * 100,\n\n      reward_type: reward_type\n    }\n  });\n\n}\n\nreturn output;"
        },
