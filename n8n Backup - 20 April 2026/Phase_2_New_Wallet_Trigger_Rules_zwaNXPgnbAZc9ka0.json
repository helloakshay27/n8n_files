    "name": "Phase 2 New Wallet Trigger Rules",
    "description": null,
    "active": false,
    "isArchived": false,
    "nodes": [
      {
        "parameters": {
          "rule": {
            "interval": [
              {
                "field": "months"
              }
            ]
          }
        },
        "type": "n8n-nodes-base.scheduleTrigger",
        "typeVersion": 1.3,
        "position": [
          -608,
          0
        ],
        "id": "b5f02622-42d4-478f-a9ae-071a76dda476",
        "name": "Schedule Trigger",
        "alwaysOutputData": true
      },
      {
        "parameters": {
          "jsCode": "const BASE_TASK_POINTS = 100; // 1% monthly variable (dummy for now)\n\nconst output = [];\n\nfor (const item of $input.all()) {\n\n  const { task_id, user_id, target_date, completed_at } = item.json;\n\n  const completed = new Date(completed_at);\n  const target = new Date(target_date);\n\n  const diffHours = (target - completed) / (1000 * 60 * 60);\n\n  let multiplier = 0;\n  let reason = '';\n\n  if (diffHours >= 12) {\n    multiplier = 1.05;\n    reason = 'Completed 12+ hours before deadline';\n  } \n  else if (diffHours >= 6) {\n    multiplier = 1.02;\n    reason = 'Completed 6–12 hours before deadline';\n  } \n  else if (diffHours >= 0) {\n    multiplier = 1.0;\n    reason = 'Completed on time';\n  } \n  else if (diffHours >= -12) {\n    multiplier = 0.75;\n    reason = 'Completed within 12 hours after deadline';\n  } \n  else if (diffHours >= -24) {\n    multiplier = 0.5;\n    reason = 'Completed within 24 hours after deadline';\n  } \n  else {\n    continue; // no reward\n  }\n\n  const reward_amount = Math.round(BASE_TASK_POINTS * multiplier);\n\n  output.push({\n    json: {\n      task_id,\n      user_id,\n      reward_amount,\n      multiplier,\n      reason\n    }\n  });\n}\n\nreturn output;\n"
        },
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          -224,
          -128
        ],
        "id": "b6a7d813-ad57-4fc0-9870-7dd4c422eedb",
        "name": "Code in JavaScript",
        "alwaysOutputData": true
      },
      {
        "parameters": {
          "conditions": {
            "options": {
              "caseSensitive": true,
              "leftValue": "",
              "typeValidation": "loose",
              "version": 3
            },
            "conditions": [
              {
                "id": "ae716a84-f13d-4d7e-b0a2-b4d1f25be180",
                "leftValue": "={{$json.reward_amount}}",
                "rightValue": 0,
                "operator": {
                  "type": "number",
                  "operation": "gt"
                }
              }
            ],
            "combinator": "and"
          },
          "looseTypeValidation": true,
          "options": {}
        },
        "type": "n8n-nodes-base.if",
        "typeVersion": 2.3,
        "position": [
          -32,
          -96
        ],
        "id": "1fdd5aae-1674-45ed-a4d9-18a6e4340f6e",
        "name": "If",
        "alwaysOutputData": true
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT\n  t.id AS task_id,\n  t.responsible_person_id AS user_id,\n  t.target_date,\n  t.completed_at\nFROM task_managements t\nWHERE\n  t.status = 'completed'\n  AND t.completed_at >= UTC_TIMESTAMP() - INTERVAL 24 HOUR\n  AND t.id NOT IN (\n    SELECT resource_id\n    FROM wallet_transactions\n    WHERE resource_type = 'TaskManagement'\n      AND point_type = 'task_reward'\n  );\n",
          "options": {}
        },
        "type": "n8n-nodes-base.mySql",
        "typeVersion": 2.5,
        "position": [
          -400,
          -112
        ],
        "id": "f377d02e-7e1e-4c5e-8fb3-fc5002006b00",
        "name": "Get Newly Completed Tasks",
        "alwaysOutputData": true,
        "credentials": {
          "mySql": {
            "id": "FGCPCtEG47rFAJ4J",
            "name": "New FM UAT Task Management Database"
          }
        }
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "INSERT INTO wallet_transactions (\n  transaction_type,\n  amount,\n  booked_member_id,\n  wallet_id,\n  resource_type,\n  resource_id,\n  remarks,\n  earned_at,\n  point_type,\n  created_at,\n  updated_at\n)\nVALUES (\n  'credit',\n  {{ $json.reward_amount }},\n  {{ $json.user_id }},\n  (SELECT id FROM wallets WHERE user_id = {{ $json.user_id }} LIMIT 1),\n  'TaskManagement',\n  {{ $json.task_id }},\n  '{{ $json.reason }}',\n  UTC_TIMESTAMP(),\n  'task_reward',\n  UTC_TIMESTAMP(),\n  UTC_TIMESTAMP()\n);\n",
          "options": {}
        },
        "type": "n8n-nodes-base.mySql",
        "typeVersion": 2.5,
        "position": [
