          }
        }
      },
      {
        "parameters": {
          "operation": "executeQuery",
          "query": "UPDATE wallets\nSET\n  credited_amount = credited_amount + {{ $json.reward_amount }},\n  available_amount = available_amount + {{ $json.reward_amount }},\n  updated_at = UTC_TIMESTAMP()\nWHERE user_id = {{ $json.user_id }};\n",
