      {
        "parameters": {
          "operation": "executeQuery",
          "query": "SELECT\n  i.*,\n  i.id                    AS issue_id,\n  i.title                 AS issue_title,\n  i.created_at            AS issue_created_at,\n  i.status                AS issue_status,\n  i.priority              AS issue_priority,\n\n  pm.id                   AS project_id,\n  pm.title                AS project_title,\n\n  -- issue owner\n  io.email                AS issue_owner_email,\n  io.firstname            AS issue_owner_firstname,\n  io.lastname             AS issue_owner_lastname,\n\n  -- project manager\n  pmo.email               AS project_manager_email,\n  pmo.firstname           AS project_manager_firstname,\n  pmo.lastname            AS project_manager_lastname,\n\n  -- created by user\n  cb.firstname            AS created_by_firstname,\n  cb.lastname             AS created_by_lastname,\n\n  -- milestone title\n  m.title                 AS milestone_title,\n\n  -- task title\n  tm.title                AS task_title\n\nFROM issues i\n\n-- issue owner\nJOIN spree_users io\n  ON io.id = i.responsible_person_id\n\n-- project\nJOIN project_managements pm\n  ON pm.id = i.project_management_id\n\n-- project manager\nJOIN spree_users pmo\n  ON pmo.id = pm.owner_id\n\n-- created by user\nLEFT JOIN spree_users cb\n  ON cb.id = i.created_by_id\n\n-- milestone\nLEFT JOIN milestones m\n  ON m.id = i.milestone_id\n\n-- task management\nLEFT JOIN task_managements tm\n  ON tm.id = i.task_management_id\n\nWHERE\n  i.created_at >= UTC_TIMESTAMP() - INTERVAL 10 MINUTE;",
          "options": {}
